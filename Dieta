function ClientsList({ clients, loading, onSelect }) {
  const [search, setSearch] = useState('');
  const filtered = clients.filter(c =>
    (c.name || '').toLowerCase().includes(search.toLowerCase())
  );

  if (loading) return (
    <div style={{ textAlign: 'center', padding: 40 }}>
      <p style={{ color: C.textMuted }}>Carregando clientes...</p>
    </div>
  );

  return (
    <div style={{ padding: '0 16px' }}>
      {/* Busca */}
      <div style={styles.searchBox}>
        <span>🔍</span>
        <input
          style={styles.searchInput}
          placeholder="Buscar cliente..."
          value={search}
          onChange={e => setSearch(e.target.value)}
        />
      </div>

      {/* Cards de clientes */}
      {filtered.length === 0 ? (
        <div style={styles.emptyState}>
          <p style={{ fontSize: 36 }}>👥</p>
          <p style={{ color: C.textMuted }}>
            {clients.length === 0
              ? 'Nenhum cliente cadastrado ainda.'
              : 'Nenhum cliente encontrado.'}
          </p>
          <p style={{ fontSize: 12, color: C.textMuted }}>
            Clientes se vinculam ao usar o app com seu código de profissional.
          </p>
        </div>
      ) : (
        filtered.map(client => (
          <ClientCard key={client.uid} client={client} onSelect={() => onSelect(client)} />
        ))
      )}
    </div>
  );
}

function ClientCard({ client, onSelect }) {
  const goalLabel = GOALS[client.goal]?.label || '—';
  const initials  = (client.name || 'C').split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);

  return (
    <button onClick={onSelect} style={styles.clientCard}>
      <div style={styles.clientAvatar}>
        <span style={styles.clientInitials}>{initials}</span>
      </div>
      <div style={styles.clientInfo}>
        <p style={styles.clientName}>{client.name || 'Sem nome'}</p>
        <p style={styles.clientMeta}>
          {client.age}a · {client.weight}kg · {goalLabel}
        </p>
        <p style={styles.clientMeta}>
          {client.sex === 'male' ? '♂' : '♀'} · {ACTIVITY_FACTORS[client.activityLevel]?.label || '—'}
        </p>
      </div>
      <div style={styles.clientRight}>
        <span style={{
          ...styles.clientBadge,
          backgroundColor: `${C.accent}22`,
