export const getFoodById = (id) => FOODS.find(f => f.id === id) || null;

export const getFoodsByCategory = (category) => FOODS.filter(f => f.category === category);

export const searchFoods = (query) => {
  const q = query.toLowerCase().trim();
  return FOODS.filter(f =>
    f.name.toLowerCase().includes(q) ||
    (f.tags && f.tags.some(t => t.includes(q)))
  );
};

export const filterFoodsByRestrictions = (foods, restrictions = {}) => {
  return foods.filter(food => {
    if (restrictions.lactoseIntolerance && !food.flags.includes('lactose_free')) return false;
    if (restrictions.glutenIntolerance  && !food.flags.includes('gluten_free'))  return false;
    if (restrictions.vegan              && !food.flags.includes('vegan'))         return false;
    if (restrictions.vegetarian         && !food.flags.includes('vegetarian') && !food.flags.includes('vegan')) return false;
    if (restrictions.diabetes           && !food.flags.includes('diabetic_ok'))  return false;
    return true;
  });
};

/**
 * Calcula macros de uma porção do alimento
 * @param {Object} food  - objeto do alimento
 * @param {number} grams - quantidade em gramas
 */
export const calculateFoodMacros = (food, grams) => {
  const ratio = grams / 100;
  return {
    calories: parseFloat((food.calories * ratio).toFixed(1)),
    protein:  parseFloat((food.protein  * ratio).toFixed(1)),
    carbs:    parseFloat((food.carbs    * ratio).toFixed(1)),
    fat:      parseFloat((food.fat      * ratio).toFixed(1)),
  };
};
