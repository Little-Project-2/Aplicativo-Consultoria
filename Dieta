/**
 * FitPro — Tela de Refeições
 * Lista todas as refeições do dia, permite adicionar/remover alimentos,
 * buscar no banco de alimentos e acionar substituições.
 */

import React, { useState, useMemo, useCallback } from 'react';
import { usePlan, useDailyLog, useActions } from '../context/AppContext';
import { FOODS, searchFoods, calculateFoodMacros, filterFoodsByRestrictions, FOOD_CATEGORIES } from '../data/foodDatabase';
import { findSubstitutes } from '../utils/substitutionAlgorithm';
import { useProfile } from '../context/AppContext';

// ─── Cores ──────────────────────────────────
const C = {
  bg:        '#0A0F1E',
  surface:   '#111827',
  card:      '#1F2937',
  border:    '#374151',
  accent:    '#00FF94',
  text:      '#F9FAFB',
  textMuted: '#9CA3AF',
  error:     '#EF4444',
  warning:   '#F59E0B',
  blue:      '#60A5FA',
  protein:   '#EF4444',
  carbs:     '#F59E0B',
  fat:       '#8B5CF6',
};

// ─────────────────────────────────────────────
// TELA PRINCIPAL
// ─────────────────────────────────────────────

export default function MealsScreen() {
  const plan    = usePlan();
  const log     = useDailyLog();
  const profile = useProfile();
  const { addFoodToMeal, removeFoodFromMeal, navigate } = useActions();

  // Modal states
  const [modal, setModal] = useState(null); // null | 'addFood' | 'substitution' | 'photo'
  const [modalData, setModalData] = useState(null);

  // Expandir/colapsar refeição
  const [expandedMeal, setExpandedMeal] = useState(plan?.meals?.[0]?.id || null);

  const meals = plan?.meals || [];

  const openAddFood = (mealId, mealName) => {
    setModalData({ mealId, mealName });
    setModal('addFood');
  };

  const openSubstitution = (mealId, foodEntry) => {
    setModalData({ mealId, foodEntry });
    setModal('substitution');
  };

  const handleAddFood = useCallback((mealId, food, grams) => {
    const macros = calculateFoodMacros(food, grams);
    const entry  = {
      id:      `entry_${Date.now()}`,
      foodId:  food.id,
      name:    food.name,
      grams,
      macros,
      addedAt: new Date().toISOString(),
    };
    addFoodToMeal(mealId, entry);
    setModal(null);
  }, [addFoodToMeal]);

  const handleRemoveFood = useCallback((mealId, entryId) => {
    removeFoodFromMeal(mealId, entryId);
  }, [removeFoodFromMeal]);

  const handleSubstitute = useCallback((mealId, oldEntryId, newFood, newGrams) => {
    // Remove antigo e adiciona novo
    removeFoodFromMeal(mealId, oldEntryId);
    const macros = calculateFoodMacros(newFood, newGrams);
    addFoodToMeal(mealId, {
      id:      `entry_${Date.now()}`,
      foodId:  newFood.id,
      name:    newFood.name,
      grams:   newGrams,
      macros,
      addedAt: new Date().toISOString(),
    });
    setModal(null);
  }, [addFoodToMeal, removeFoodFromMeal]);

  return (
    <div style={styles.container}>
      {/* Header */}
      <div style={styles.header}>
        <button onClick={() => navigate('dashboard')} style={styles.backBtn}>←</button>
        <h1 style={styles.headerTitle}>Refeições do Dia</h1>
        <div style={{ width: 40 }} />
      </div>

      {/* Resumo rápido */}
      <DailySummaryBar log={log} plan={plan} />

      {/* Lista de refeições */}
      <div style={styles.scroll}>
        {meals.map(meal => {
          const mealLog  = log.meals[meal.id] || { foods: [] };
          const consumed = mealLog.foods.reduce((a, f) => ({
            calories: a.calories + (f.macros?.calories || 0),
            protein:  a.protein  + (f.macros?.protein  || 0),
            carbs:    a.carbs    + (f.macros?.carbs    || 0),
            fat:      a.fat      + (f.macros?.fat      || 0),
          }), { calories: 0, protein: 0, carbs: 0, fat: 0 });

          return (
            <MealSection
              key={meal.id}
              meal={meal}
              foods={mealLog.foods}
              consumed={consumed}
              isExpanded={expandedMeal === meal.id}
              onToggle={() => setExpandedMeal(prev => prev === meal.id ? null : meal.id)}
              onAddFood={() => openAddFood(meal.id, meal.name)}
              onRemoveFood={(entryId) => handleRemoveFood(meal.id, entryId)}
              onSubstitute={(entry) => openSubstitution(meal.id, entry)}
            />
          );
        })}
        <div style={{ height: 100 }} />
      </div>

      {/* Modal: Adicionar Alimento */}
      {modal === 'addFood' && modalData && (
        <AddFoodModal
          mealName={modalData.mealName}
          restrictions={profile?.restrictions || {}}
          onAdd={(food, grams) => handleAddFood(modalData.mealId, food, grams)}
          onClose={() => setModal(null)}
        />
      )}

      {/* Modal: Substituição */}
      {modal === 'substitution' && modalData && (
        <SubstitutionModal
          entry={modalData.foodEntry}
          restrictions={profile?.restrictions || {}}
          onConfirm={(newFood, newGrams) =>
            handleSubstitute(modalData.mealId, modalData.foodEntry.id, newFood, newGrams)
          }
          onClose={() => setModal(null)}
        />
      )}
    </div>
  );
}

