// Componentes globais
import { BottomNav, Toast, LoadingOverlay, SplashScreen } from './components/UI';

// ─────────────────────────────────────────────
// ROTEADOR
// ─────────────────────────────────────────────

function Router() {
  const { activeScreen } = useUI();

  const Screen = {
    splash:       SplashScreen,
    landing:      LandingScreen,
    onboarding:   OnboardingScreen,
    dashboard:    DashboardScreen,
    meals:        MealsScreen,
    recipes:      RecipesScreen,
    profile:      ProfileScreen,
    professional: ProfessionalScreen,
  }[activeScreen] || SplashScreen;

  return (
    <div style={appStyles.root}>
      <Screen />
      <BottomNav />
      <Toast />
      <LoadingOverlay />
    </div>
  );
}

