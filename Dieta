export function validateUserProfile(data) {
  const errors = {};

  if (!data.weight || data.weight < 30 || data.weight > 300)
    errors.weight = 'Peso deve ser entre 30 e 300 kg';

  if (!data.height || data.height < 100 || data.height > 250)
    errors.height = 'Altura deve ser entre 100 e 250 cm';

  if (!data.age || data.age < 10 || data.age > 100)
    errors.age = 'Idade deve ser entre 10 e 100 anos';

  if (!['male', 'female'].includes(data.sex))
    errors.sex = 'Sexo inválido';

  if (!ACTIVITY_FACTORS[data.activityLevel])
    errors.activityLevel = 'Nível de atividade inválido';

  if (!GOALS[data.goal])
    errors.goal = 'Objetivo inválido';

  return { isValid: Object.keys(errors).length === 0, errors };
}

