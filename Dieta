function ProfileTab({ profile, plan }) {
  const rows = [
    { label: 'Peso',       value: `${profile.weight} kg` },
    { label: 'Altura',     value: `${profile.height} cm` },
    { label: 'Idade',      value: `${profile.age} anos` },
    { label: 'Sexo',       value: profile.sex === 'male' ? 'Masculino' : 'Feminino' },
    { label: 'Nível Treino',value: profile.trainingLevel === 'beginner' ? 'Iniciante' : profile.trainingLevel === 'advanced' ? 'Avançado' : 'Intermediário' },
    { label: 'Atividade',  value: ACTIVITY_FACTORS[profile.activityLevel]?.label || '—' },
    { label: 'Objetivo',   value: GOALS[profile.goal]?.label || '—' },
    { label: 'Refeições',  value: `${profile.mealCount}x por dia` },
    { label: 'Água/dia',   value: `${(plan.waterMl / 1000).toFixed(1)} L` },
  ];

  const activeRestrictions = Object.entries(profile.restrictions || {})
    .filter(([, v]) => v)
    .map(([k]) => ({
      lactoseIntolerance: '🥛 Sem Lactose',
      glutenIntolerance:  '🌾 Sem Glúten',
      diabetes:           '💉 Diabetes',
      vegan:              '🌱 Vegano',
      vegetarian:         '🥦 Vegetariano',
      hypertension:       '❤️ Hipertensão',
    }[k] || k));

  return (
    <div style={styles.tabContent}>
      {/* Dados */}
      <div style={styles.infoCard}>
        {rows.map(row => (
          <div key={row.label} style={styles.infoRow}>
            <span style={styles.infoLabel}>{row.label}</span>
            <span style={styles.infoValue}>{row.value}</span>
          </div>
        ))}
      </div>

      {/* Restrições */}
      {activeRestrictions.length > 0 && (
        <>
          <h3 style={styles.sectionTitle}>⚠️ Restrições e Condições</h3>
          <div style={styles.restrictionsRow}>
            {activeRestrictions.map(r => (
              <span key={r} style={styles.restrictionTag}>{r}</span>
            ))}
          </div>
          {profile.otherConditions && (
            <p style={styles.otherCond}>Outras: {profile.otherConditions}</p>
          )}
        </>
      )}

      {/* Peso ideal */}
      {plan.idealWeightRange && (
        <div style={styles.idealWeight}>
          <p style={styles.idealWeightTitle}>📏 Faixa de Peso Ideal (Devine)</p>
          <p style={styles.idealWeightRange}>
            {plan.idealWeightRange.min} – {plan.idealWeightRange.max} kg
          </p>
        </div>
      )}
    </div>
  );
}

