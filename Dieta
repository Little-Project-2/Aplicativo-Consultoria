 * FitPro — Firebase Service Layer
 *
 * Abstrai todas as operações com Firestore/Auth.
 * Se Firebase não estiver configurado, usa localStorage como fallback (dev mode).
 */

// ── FIREBASE CONFIG ─────────────────────────────────────────────
// Substitua com suas credenciais reais em produção
const FIREBASE_CONFIG = {
  apiKey:            process.env.REACT_APP_FIREBASE_API_KEY            || 'demo',
  authDomain:        process.env.REACT_APP_FIREBASE_AUTH_DOMAIN        || 'demo.firebaseapp.com',
  projectId:         process.env.REACT_APP_FIREBASE_PROJECT_ID         || 'fitpro-demo',
  storageBucket:     process.env.REACT_APP_FIREBASE_STORAGE_BUCKET     || 'fitpro-demo.appspot.com',
  messagingSenderId: process.env.REACT_APP_FIREBASE_MESSAGING_SENDER_ID|| '000000',
  appId:             process.env.REACT_APP_FIREBASE_APP_ID             || '1:000:web:000',
};

const USE_MOCK = process.env.REACT_APP_USE_MOCK === 'true' || !process.env.REACT_APP_FIREBASE_API_KEY;

// ── LOCAL STORAGE MOCK (dev) ─────────────────────────────────────

const MOCK_DELAY = 150; // ms
const delay = (ms) => new Promise(r => setTimeout(r, ms));

const storage = {
  get: (key) => {
    try { return JSON.parse(localStorage.getItem(key)); }
    catch { return null; }
  },
  set: (key, val) => {
    try { localStorage.setItem(key, JSON.stringify(val)); return true; }
    catch { return false; }
  },
  del: (key) => { localStorage.removeItem(key); },
};

// ── AUTH SERVICE ─────────────────────────────────────────────────

export const authService = {

  /**
   * Retorna usuário atual (mock: lê do storage)
   */
  getCurrentUser: async () => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      return storage.get('fitpro_current_user') || null;
    }
    // Em produção: return firebase.auth().currentUser
    throw new Error('Firebase não configurado');
  },

  /**
   * Login com email e senha
   */
  signIn: async (email, password) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const users = storage.get('fitpro_users') || {};
      const user = Object.values(users).find(u => u.email === email);
      if (!user || user.password !== password) throw new Error('Credenciais inválidas');
      storage.set('fitpro_current_user', { uid: user.uid, email: user.email, role: user.role });
      return { uid: user.uid, email: user.email, role: user.role };
    }
    throw new Error('Firebase não configurado');
  },

  /**
   * Cadastro
   */
  signUp: async (email, password, displayName) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const uid = `user_${Date.now()}`;
      const users = storage.get('fitpro_users') || {};
      if (Object.values(users).find(u => u.email === email))
        throw new Error('E-mail já cadastrado');
      users[uid] = { uid, email, password, displayName, role: 'client', createdAt: new Date().toISOString() };
      storage.set('fitpro_users', users);
      storage.set('fitpro_current_user', { uid, email, role: 'client', displayName });
      return { uid, email, role: 'client', displayName };
    }
    throw new Error('Firebase não configurado');
  },

  signOut: async () => {
    if (USE_MOCK) {
      await delay(50);
      storage.del('fitpro_current_user');
      return;
    }
    throw new Error('Firebase não configurado');
  },
};

