// ── DAILY LOG SERVICE ─────────────────────────────────────────────

export const dailyLogService = {

  /**
   * Salva/atualiza log diário de refeições
   */
  saveDailyLog: async (uid, date, logData) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const logs = storage.get('fitpro_logs') || {};
      if (!logs[uid]) logs[uid] = {};
      logs[uid][date] = {
        ...logData,
        uid,
        date,
        savedAt: new Date().toISOString(),
      };
      storage.set('fitpro_logs', logs);
      return logs[uid][date];
    }
  },

  getDailyLog: async (uid, date) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const logs = storage.get('fitpro_logs') || {};
      return (logs[uid] && logs[uid][date]) || null;
    }
  },

  getWeekLogs: async (uid, startDate) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const logs = storage.get('fitpro_logs') || {};
      const userLogs = logs[uid] || {};
      const start = new Date(startDate);
      return Object.entries(userLogs)
        .filter(([date]) => new Date(date) >= start)
        .map(([date, log]) => ({ date, ...log }))
        .sort((a, b) => new Date(a.date) - new Date(b.date));
    }
  },

  /**
   * Adiciona um alimento a uma refeição do dia
   */
  addFoodToMeal: async (uid, date, mealId, foodEntry) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const logs = storage.get('fitpro_logs') || {};
      if (!logs[uid]) logs[uid] = {};
      if (!logs[uid][date]) logs[uid][date] = { meals: {} };
      if (!logs[uid][date].meals) logs[uid][date].meals = {};
      if (!logs[uid][date].meals[mealId]) logs[uid][date].meals[mealId] = { foods: [] };

      const entry = {
        ...foodEntry,
        id: `entry_${Date.now()}`,
        addedAt: new Date().toISOString(),
      };
      logs[uid][date].meals[mealId].foods.push(entry);
      storage.set('fitpro_logs', logs);
      return entry;
    }
  },

  removeFoodFromMeal: async (uid, date, mealId, entryId) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const logs = storage.get('fitpro_logs') || {};
      const meal = logs?.[uid]?.[date]?.meals?.[mealId];
      if (!meal) return;
      meal.foods = meal.foods.filter(f => f.id !== entryId);
      storage.set('fitpro_logs', logs);
    }
  },
};

