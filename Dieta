function SubstitutionModal({ entry, restrictions, onConfirm, onClose }) {
  const substitutes = useMemo(() =>
    findSubstitutes(entry.foodId, entry.grams, restrictions, 6),
    [entry.foodId, entry.grams, restrictions]
  );

  return (
    <div style={styles.overlay}>
      <div style={styles.modal}>
        <div style={styles.modalHeader}>
          <h2 style={styles.modalTitle}>Substituir Alimento</h2>
          <button onClick={onClose} style={styles.closeBtn}>✕</button>
        </div>

        <div style={styles.subOriginal}>
          <p style={styles.subOriginalLabel}>Substituindo:</p>
          <p style={styles.subOriginalName}>{entry.name} ({entry.grams}g)</p>
          <div style={styles.subOriginalMacros}>
            {[
              { l: 'Kcal', v: Math.round(entry.macros?.calories || 0) },
              { l: 'P',    v: `${Math.round(entry.macros?.protein || 0)}g` },
              { l: 'C',    v: `${Math.round(entry.macros?.carbs || 0)}g` },
              { l: 'G',    v: `${Math.round(entry.macros?.fat || 0)}g` },
            ].map(m => (
              <span key={m.l} style={styles.subMacroBadge}>{m.l}: {m.v}</span>
            ))}
          </div>
        </div>

        <p style={styles.subListTitle}>Melhores substitutos:</p>
        <div style={styles.subList}>
          {substitutes.length === 0 ? (
            <p style={styles.emptyText}>Nenhum substituto compatível encontrado</p>
          ) : (
            substitutes.map((sub) => (
              <button
                key={sub.food.id}
                onClick={() => onConfirm(sub.food, sub.gramsNeeded)}
                style={styles.subItem}
              >
                <div style={styles.subItemLeft}>
                  <div style={styles.subItemTop}>
                    <p style={styles.subItemName}>{sub.food.name}</p>
                    <span style={{
                      ...styles.subQualityBadge,
                      backgroundColor: `${sub.matchQuality.color}22`,
                      color: sub.matchQuality.color,
                      borderColor: `${sub.matchQuality.color}44`,
                    }}>
                      {sub.matchQuality.icon} {sub.matchQuality.label}
                    </span>
                  </div>
                  <p style={styles.subItemMeta}>
                    {sub.gramsNeeded}g · {Math.round(sub.macros.calories)} kcal · P:{Math.round(sub.macros.protein)}g C:{Math.round(sub.macros.carbs)}g G:{Math.round(sub.macros.fat)}g
                  </p>
                </div>
                <span style={styles.subArrow}>→</span>
              </button>
            ))
          )}
        </div>
      </div>
    </div>
  );
}

