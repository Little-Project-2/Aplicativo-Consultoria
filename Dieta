      <div style={styles.macrosCard}>
        <MacroDetailRow
          label="Proteína"
          g={plan.macros.protein.g}
          kcal={plan.macros.protein.kcal}
          pct={plan.macros.protein.percent}
          color={C.protein}
          note={`≈ ${(plan.macros.protein.g / (useProfileWeight(plan))).toFixed(1)}g/kg`}
        />
        <MacroDetailRow
          label="Carboidratos"
          g={plan.macros.carbs.g}
          kcal={plan.macros.carbs.kcal}
          pct={plan.macros.carbs.percent}
          color={C.carbs}
        />
        <MacroDetailRow
          label="Gordura"
          g={plan.macros.fat.g}
          kcal={plan.macros.fat.kcal}
          pct={plan.macros.fat.percent}
          color={C.fat}
        />
      </div>

      {/* Distribuição por refeição */}
      {plan.meals && plan.meals.length > 0 && (
        <>
          <h3 style={styles.sectionTitle}>📋 Distribuição por Refeição</h3>
          <div style={styles.mealsTable}>
            {plan.meals.map(meal => (
              <div key={meal.id} style={styles.mealTableRow}>
                <div style={styles.mealTableName}>
                  <span style={styles.mealTableOrder}>{meal.order}</span>
                  <span style={{ fontSize: 14, color: C.text }}>{meal.name}</span>
                </div>
                <div style={styles.mealTableMacros}>
                  <span style={styles.mealTableKcal}>{meal.targets.calories} kcal</span>
                  <span style={styles.mealTableMeta}>
                    P:{meal.targets.protein}g C:{meal.targets.carbs}g G:{meal.targets.fat}g
                  </span>
                </div>
                <span style={styles.mealTablePct}>{meal.percentage}%</span>
              </div>
            ))}
          </div>
        </>
      )}

      {/* Data de criação */}
      <p style={styles.planDate}>
        📅 Plano criado em {new Date(plan.createdAt).toLocaleDateString('pt-BR')}
        {plan.updatedAt !== plan.createdAt &&
          ` · Atualizado em ${new Date(plan.updatedAt).toLocaleDateString('pt-BR')}`
        }
      </p>
    </div>
  );
}

// hack simples para pegar peso do plano via meta
function useProfileWeight(plan) {
  // O plano não guarda o peso diretamente, estimamos via proteína/multiplicador
  // Usando proteína com multiplicador 2.0 (padrão)
  return plan.macros?.protein?.g ? plan.macros.protein.g / 2.0 : 1;
}

