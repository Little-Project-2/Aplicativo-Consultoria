/**
 * FitPro — Tela de Receitas (eBook Interativo)
 * Lista receitas, filtra por categoria/restrição, avalia e substitui refeições
 */

import React, { useState, useMemo, useCallback } from 'react';
import {
  RECIPES, RECIPE_CATEGORIES,
  searchRecipes, filterRecipesByRestrictions, getRecipeById,
} from '../data/recipeDatabase';
import { findCompatibleRecipes } from '../utils/substitutionAlgorithm';
import { useProfile, usePlan, useActions } from '../context/AppContext';
import { feedbackService } from '../services/firebase';

const C = {
  bg: '#0A0F1E', surface: '#111827', card: '#1F2937', border: '#374151',
  accent: '#00FF94', text: '#F9FAFB', textMuted: '#9CA3AF',
  error: '#EF4444', warning: '#F59E0B', blue: '#60A5FA',
  protein: '#EF4444', carbs: '#F59E0B', fat: '#8B5CF6',
};

// ─────────────────────────────────────────────
// TELA PRINCIPAL
// ─────────────────────────────────────────────

export default function RecipesScreen() {
  const profile = useProfile();
  const plan    = usePlan();
  const { navigate, showToast } = useActions();

  const [query, setQuery]         = useState('');
  const [category, setCategory]   = useState('all');
  const [viewMode, setViewMode]   = useState('grid'); // grid | list
  const [selected, setSelected]   = useState(null);   // receita aberta
  const [ratingModal, setRatingModal] = useState(null);

  const restrictions = profile?.restrictions || {};

  const filtered = useMemo(() => {
    let pool = query.length >= 2 ? searchRecipes(query) : RECIPES;
    if (category !== 'all') pool = pool.filter(r => r.category === category);
    return filterRecipesByRestrictions(pool, restrictions);
  }, [query, category, restrictions]);

  const handleRate = useCallback(async (recipeId, rating, comment) => {
    const uid = profile?.uid;
    if (uid) await feedbackService.rateRecipe(uid, recipeId, rating, comment);
    setRatingModal(null);
    showToast({ message: `⭐ Avaliação enviada! Obrigado.`, type: 'success' });
  }, [profile?.uid, showToast]);

  if (selected) {
    return (
      <RecipeDetail
        recipe={selected}
        plan={plan}
        restrictions={restrictions}
        onBack={() => setSelected(null)}
        onRate={() => setRatingModal(selected.id)}
        showToast={showToast}
      />
    );
  }

  return (
    <div style={styles.container}>
      {/* Header */}
      <div style={styles.header}>
        <button onClick={() => navigate('dashboard')} style={styles.backBtn}>←</button>
        <h1 style={styles.headerTitle}>📖 Receitas</h1>
        <button onClick={() => setViewMode(v => v === 'grid' ? 'list' : 'grid')} style={styles.viewToggle}>
          {viewMode === 'grid' ? '☰' : '⊞'}
        </button>
      </div>

      {/* Busca */}
      <div style={styles.searchRow}>
        <div style={styles.searchBox}>
          <span style={{ fontSize: 16 }}>🔍</span>
          <input
            style={styles.searchInput}
            placeholder="Buscar receita..."
            value={query}
            onChange={e => setQuery(e.target.value)}
          />
          {query && (
            <button onClick={() => setQuery('')} style={styles.clearBtn}>✕</button>
          )}
        </div>
      </div>

      {/* Categorias */}
      <div style={styles.categoriesScroll}>
        <button
          onClick={() => setCategory('all')}
          style={{ ...styles.catChip, ...(category === 'all' ? styles.catChipActive : {}) }}
        >
          🍽️ Todas
        </button>
        {Object.values(RECIPE_CATEGORIES).map(cat => (
          <button
            key={cat.id}
            onClick={() => setCategory(cat.id)}
            style={{ ...styles.catChip, ...(category === cat.id ? styles.catChipActive : {}) }}
          >
            {cat.icon} {cat.label}
          </button>
        ))}
      </div>

      {/* Contador */}
      <p style={styles.countLabel}>{filtered.length} receita{filtered.length !== 1 ? 's' : ''} encontrada{filtered.length !== 1 ? 's' : ''}</p>

      {/* Grid / List */}
      <div style={styles.scroll}>
        <div style={viewMode === 'grid' ? styles.grid : styles.list}>
          {filtered.map(recipe => (
            viewMode === 'grid'
              ? <RecipeCard key={recipe.id} recipe={recipe} onClick={() => setSelected(recipe)} />
              : <RecipeListItem key={recipe.id} recipe={recipe} onClick={() => setSelected(recipe)} />
          ))}
        </div>
        {filtered.length === 0 && (
          <div style={styles.emptyState}>
            <p style={{ fontSize: 40 }}>🍽️</p>
            <p style={{ color: C.textMuted }}>Nenhuma receita encontrada</p>
          </div>
        )}
        <div style={{ height: 100 }} />
      </div>

      {/* Rating Modal */}
      {ratingModal && (
        <RatingModal
          recipeId={ratingModal}
          recipeName={getRecipeById(ratingModal)?.name || ''}
          onSubmit={handleRate}
          onClose={() => setRatingModal(null)}
        />
      )}
    </div>
  );
}

