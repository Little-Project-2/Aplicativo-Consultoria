// ─────────────────────────────────────────────
// COMPONENTE PRINCIPAL
// ─────────────────────────────────────────────

export default function OnboardingScreen() {
  const { completeOnboarding, navigate } = useActions();

  const [step, setStep] = useState(1);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [errors, setErrors] = useState({});

  const [formData, setFormData] = useState({
    // Dados pessoais
    name:          '',
    weight:        '',
    height:        '',
    age:           '',
    sex:           '',

    // Treino
    activityLevel: '',
    trainingLevel: 'intermediate',

    // Objetivo
    goal:          '',

    // Alimentação
    mealCount:     4,
    mealPreference:'fixed',   // fixed | flexible

    // Restrições
    restrictions: {
      lactoseIntolerance: false,
      glutenIntolerance:  false,
      diabetes:           false,
      vegan:              false,
      vegetarian:         false,
      hypertension:       false,
    },

    // Outras doenças
    otherConditions: '',
  });

  const update = useCallback((field, value) => {
    setFormData(prev => ({ ...prev, [field]: value }));
    setErrors(prev => ({ ...prev, [field]: undefined }));
  }, []);

  const updateRestriction = useCallback((key, value) => {
    setFormData(prev => ({
      ...prev,
      restrictions: { ...prev.restrictions, [key]: value },
    }));
  }, []);

  const canAdvance = () => {
    switch (step) {
      case 1: return formData.name.trim().length >= 2;
      case 2: return formData.weight && formData.height && formData.age && formData.sex;
      case 3: return formData.activityLevel !== '';
      case 4: return formData.goal !== '';
      case 5: return true;
      case 6: return true;
      default: return false;
    }
  };

  const handleNext = () => {
    if (step < STEPS.length) setStep(s => s + 1);
  };

  const handleBack = () => {
    if (step > 1) setStep(s => s - 1);
  };

  const handleSubmit = async () => {
    const numericData = {
      ...formData,
      weight: parseFloat(formData.weight),
      height: parseFloat(formData.height),
      age:    parseInt(formData.age),
      mealCount: parseInt(formData.mealCount),
    };

    const { isValid, errors: valErrors } = validateUserProfile(numericData);
    if (!isValid) {
      setErrors(valErrors);
      setStep(2); // volta para dados pessoais
      return;
    }

    setIsSubmitting(true);
    try {
      await completeOnboarding(numericData);
    } catch (e) {
      console.error(e);
    } finally {
      setIsSubmitting(false);
    }
  };

  const progress = (step / STEPS.length) * 100;

  return (
    <div style={styles.container}>
      {/* Barra de progresso */}
      <div style={styles.progressBar}>
        <div style={{ ...styles.progressFill, width: `${progress}%` }} />
      </div>

      {/* Header */}
      <div style={styles.header}>
        <div style={styles.stepBadge}>
          <span style={styles.stepText}>{step}/{STEPS.length}</span>
        </div>
        <h1 style={styles.title}>{STEPS[step - 1].title}</h1>
        <p style={styles.subtitle}>{STEPS[step - 1].subtitle}</p>
      </div>

      {/* Conteúdo da etapa */}
      <div style={styles.content}>
        {step === 1 && <StepWelcome formData={formData} update={update} />}
        {step === 2 && <StepBody     formData={formData} update={update} errors={errors} />}
        {step === 3 && <StepActivity formData={formData} update={update} />}
        {step === 4 && <StepGoal     formData={formData} update={update} />}
        {step === 5 && <StepDiet     formData={formData} update={update} updateRestriction={updateRestriction} />}
        {step === 6 && <StepReview   formData={formData} />}
      </div>

      {/* Navegação */}
      <div style={styles.navigation}>
        {step > 1 && (
          <button onClick={handleBack} style={styles.btnBack}>
            ← Voltar
          </button>
        )}
        {step < STEPS.length ? (
          <button
            onClick={handleNext}
            disabled={!canAdvance()}
            style={{ ...styles.btnNext, opacity: canAdvance() ? 1 : 0.4 }}
          >
            Continuar →
          </button>
        ) : (
          <button
            onClick={handleSubmit}
            disabled={isSubmitting}
            style={styles.btnSubmit}
          >
            {isSubmitting ? '⏳ Criando plano...' : '🚀 Gerar Meu Plano!'}
          </button>
        )}
      </div>
    </div>
  );
}

