// ─────────────────────────────────────────────
// IMC
// ─────────────────────────────────────────────

/**
 * Calcula IMC e classificação
 * @param {number} weight - peso em kg
 * @param {number} height - altura em cm
 * @returns {{ value: number, classification: string, color: string }}
 */
export function calculateBMI(weight, height) {
  const heightM = height / 100;
  const bmi = weight / (heightM * heightM);

  let classification, color;
  if (bmi < 18.5)       { classification = 'Abaixo do Peso';  color = '#60A5FA'; }
  else if (bmi < 25.0)  { classification = 'Peso Normal';      color = '#34D399'; }
  else if (bmi < 30.0)  { classification = 'Sobrepeso';        color = '#FBBF24'; }
  else if (bmi < 35.0)  { classification = 'Obesidade Grau I'; color = '#F97316'; }
  else if (bmi < 40.0)  { classification = 'Obesidade Grau II';color = '#EF4444'; }
  else                  { classification = 'Obesidade Grau III';color = '#991B1B';}

  return { value: parseFloat(bmi.toFixed(1)), classification, color };
}

// ─────────────────────────────────────────────
// TMB — Mifflin-St Jeor (mais preciso)
// ─────────────────────────────────────────────

/**
 * Calcula Taxa Metabólica Basal
 * @param {number} weight - kg
 * @param {number} height - cm
 * @param {number} age    - anos
 * @param {'male'|'female'} sex
 * @returns {number} TMB em kcal/dia
 */
export function calculateBMR(weight, height, age, sex) {
  const base = (10 * weight) + (6.25 * height) - (5 * age);
  return sex === 'male' ? base + 5 : base - 161;
}

// ─────────────────────────────────────────────
// TDEE — Gasto Energético Total
// ─────────────────────────────────────────────

/**
 * Calcula TDEE aplicando fator de atividade
 * @param {number} bmr
 * @param {string} activityLevel - chave de ACTIVITY_FACTORS
 * @returns {number} TDEE em kcal/dia
 */
export function calculateTDEE(bmr, activityLevel) {
  const factor = ACTIVITY_FACTORS[activityLevel]?.factor || 1.2;
  return Math.round(bmr * factor);
}

// ─────────────────────────────────────────────
// META CALÓRICA AJUSTADA POR OBJETIVO
// ─────────────────────────────────────────────

/**
 * Ajusta TDEE ao objetivo
 * @param {number} tdee
 * @param {string} goal - chave de GOALS
 * @returns {{ targetCalories: number, surplus: number, deficit: number }}
 */
export function calculateTargetCalories(tdee, goal) {
  const adjustment = GOALS[goal]?.caloricAdjustment || 0;
  const targetCalories = Math.round(tdee * (1 + adjustment));
  const diff = targetCalories - tdee;

  return {
    targetCalories,
    surplus: diff > 0 ? diff : 0,
    deficit: diff < 0 ? Math.abs(diff) : 0,
    adjustmentPercent: Math.round(Math.abs(adjustment) * 100),
  };
}

// ─────────────────────────────────────────────
// MACRONUTRIENTES
// ─────────────────────────────────────────────

/**
 * Calcula distribuição de macros completa
 * @param {number} weight          - kg
 * @param {number} targetCalories  - kcal meta
 * @param {string} goal            - chave de GOALS
 * @param {Object} [restrictions]  - restrições alimentares
 * @returns {MacroResult}
 */
export function calculateMacros(weight, targetCalories, goal, restrictions = {}) {
  const goalConfig = GOALS[goal] || GOALS.maintenance;

  // PROTEÍNA: 1.6–2.2g/kg dependendo do objetivo
  const proteinPerKg = goalConfig.proteinMultiplier;
  const proteinG = Math.round(weight * proteinPerKg);
  const proteinKcal = proteinG * 4;

  // GORDURA: 0.8–1g/kg (min 20% das calorias para saúde hormonal)
  let fatPerKg = goalConfig.fatMultiplier;
  let fatG = Math.round(weight * fatPerKg);
  let fatKcal = fatG * 9;

  // Garantir mínimo de 20% das calorias em gordura
  const minFatKcal = targetCalories * 0.20;
  if (fatKcal < minFatKcal) {
    fatKcal = Math.round(minFatKcal);
    fatG = Math.round(fatKcal / 9);
  }

  // CARBOIDRATOS: restante das calorias
  const carbKcal = targetCalories - proteinKcal - fatKcal;
  const carbG = Math.max(0, Math.round(carbKcal / 4));

  // Recalcular total real
  const totalKcal = proteinKcal + fatKcal + (carbG * 4);

  return {
    protein: { g: proteinG, kcal: proteinKcal, percent: Math.round((proteinKcal / totalKcal) * 100) },
    fat:     { g: fatG,     kcal: fatKcal,     percent: Math.round((fatKcal     / totalKcal) * 100) },
    carbs:   { g: carbG,    kcal: carbG * 4,   percent: Math.round(((carbG * 4) / totalKcal) * 100) },
    totalKcal,
  };
}

// ─────────────────────────────────────────────
// DISTRIBUIÇÃO POR REFEIÇÃO
// ─────────────────────────────────────────────

/**
 * Distribui macros entre refeições
 * @param {MacroResult} macros
 * @param {number} mealCount - número de refeições (3–6)
 * @param {string[]} [mealNames] - nomes customizados
 * @returns {MealDistribution[]}
 */
export function distributeMacrosToMeals(macros, mealCount, mealNames) {
  const percentages = MEAL_PRESETS[mealCount] || MEAL_PRESETS[4];

  const defaultNames = {
    3: ['Café da Manhã', 'Almoço', 'Jantar'],
    4: ['Café da Manhã', 'Almoço', 'Lanche da Tarde', 'Jantar'],
    5: ['Café da Manhã', 'Lanche da Manhã', 'Almoço', 'Lanche da Tarde', 'Jantar'],
    6: ['Café da Manhã', 'Lanche da Manhã', 'Almoço', 'Lanche da Tarde', 'Jantar', 'Ceia'],
  };

  const names = mealNames || defaultNames[mealCount] || defaultNames[4];

  return percentages.map((pct, index) => {
    const ratio = pct / 100;
    return {
      id: `meal_${index + 1}`,
      name: names[index] || `Refeição ${index + 1}`,
      order: index + 1,
      percentage: pct,
      targets: {
        calories: Math.round(macros.totalKcal * ratio),
        protein:  Math.round(macros.protein.g * ratio),
        carbs:    Math.round(macros.carbs.g   * ratio),
        fat:      Math.round(macros.fat.g     * ratio),
      },
      foods: [],
      consumed: { calories: 0, protein: 0, carbs: 0, fat: 0 },
    };
  });
}

// ─────────────────────────────────────────────
// PERFIL COMPLETO — FUNÇÃO PRINCIPAL
// ─────────────────────────────────────────────

/**
 * Gera perfil nutricional completo a partir dos dados do usuário
 * @param {UserProfile} user
 * @returns {NutritionProfile}
 */
export function generateNutritionProfile(user) {
  const {
    weight, height, age, sex,
    activityLevel, goal, mealCount,
    restrictions = {},
    trainingLevel = 'intermediate',
  } = user;

  const bmi    = calculateBMI(weight, height);
  const bmr    = calculateBMR(weight, height, age, sex);
  const tdee   = calculateTDEE(bmr, activityLevel);
  const target = calculateTargetCalories(tdee, goal);
  const macros = calculateMacros(weight, target.targetCalories, goal, restrictions);
  const meals  = distributeMacrosToMeals(macros, mealCount || 4);

  // Estimativa de peso ideal (Devine formula)
  const idealWeightMin = sex === 'male'
    ? 50 + 2.3 * ((height - 152.4) / 2.54)
    : 45.5 + 2.3 * ((height - 152.4) / 2.54);
  const idealWeightRange = {
    min: Math.round(idealWeightMin * 0.9),
    max: Math.round(idealWeightMin * 1.1),
  };

  // Hidratação recomendada (35ml/kg + 350ml por hora de exercício)
  const waterMl = Math.round(weight * 35);

  return {
    bmi,
    bmr: Math.round(bmr),
    tdee,
    targetCalories: target.targetCalories,
    surplus: target.surplus,
    deficit: target.deficit,
    macros,
    meals,
    idealWeightRange,
    waterMl,
    trainingLevel,
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  };
}

