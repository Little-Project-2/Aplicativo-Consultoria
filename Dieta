            style={styles.searchInput}
            placeholder="Buscar alimento..."
            value={query}
            onChange={e => setQuery(e.target.value)}
            autoFocus
          />
          {query && (
            <button onClick={() => setQuery('')} style={styles.clearBtn}>✕</button>
          )}
        </div>

        {/* Categorias */}
        <div style={styles.categoryScroll}>
          {[{ id: 'all', label: '🍽️ Todos' }, ...Object.values(FOOD_CATEGORIES)].map(cat => (
            <button
              key={cat.id}
              onClick={() => setCategory(cat.id)}
              style={{
                ...styles.categoryChip,
                ...(category === cat.id ? styles.categoryChipActive : {}),
              }}
            >
              {cat.icon} {cat.label}
            </button>
          ))}
        </div>

        {/* Alimento selecionado */}
        {selected && (
          <div style={styles.selectedFood}>
            <div style={styles.selectedFoodInfo}>
              <p style={styles.selectedName}>{selected.name}</p>
              <div style={styles.gramsRow}>
                <input
                  type="number"
                  style={styles.gramsInput}
                  value={grams}
                  onChange={e => setGrams(e.target.value)}
                  min="1" max="2000"
                />
                <span style={styles.gramsLabel}>gramas</span>
              </div>
            </div>
            {preview && (
              <div style={styles.previewMacros}>
                <PreviewMacro label="Kcal"  value={Math.round(preview.calories)} color={C.text} />
                <PreviewMacro label="Prot"  value={`${preview.protein}g`}        color={C.protein} />
                <PreviewMacro label="Carb"  value={`${preview.carbs}g`}          color={C.carbs} />
                <PreviewMacro label="Gord"  value={`${preview.fat}g`}            color={C.fat} />
              </div>
            )}
            <div style={styles.selectedActions}>
              <button onClick={() => setSelected(null)} style={styles.cancelBtn}>Cancelar</button>
              <button
                onClick={() => onAdd(selected, parseFloat(grams) || 100)}
                style={styles.confirmBtn}
              >
                ✓ Adicionar
              </button>
            </div>
          </div>
        )}

        {/* Lista de resultados */}
        {!selected && (
          <div style={styles.foodResults}>
            {results.map(food => (
              <button
                key={food.id}
                onClick={() => {
                  setSelected(food);
                  const defaultServing = food.servingSizes?.[0];
                  setGrams(defaultServing ? String(defaultServing.g) : '100');
                }}
                style={styles.foodResultItem}
              >
                <div style={styles.foodResultLeft}>
                  <p style={styles.foodResultName}>{food.name}</p>
                  <p style={styles.foodResultMeta}>
                    100g · {food.calories} kcal · P:{food.protein}g C:{food.carbs}g G:{food.fat}g
                  </p>
                </div>
                <span style={{
                  fontSize: 11,
                  backgroundColor: `${FOOD_CATEGORIES[food.category]?.color || C.blue}22`,
                  color: FOOD_CATEGORIES[food.category]?.color || C.blue,
                  padding: '2px 8px',
                  borderRadius: 10,
                  whiteSpace: 'nowrap',
                }}>
                  {FOOD_CATEGORIES[food.category]?.label || food.category}
                </span>
              </button>
            ))}
            {results.length === 0 && (
              <p style={styles.emptyText}>Nenhum alimento encontrado</p>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

function PreviewMacro({ label, value, color }) {
  return (
    <div style={{ textAlign: 'center' }}>
      <p style={{ color, fontWeight: 700, margin: 0, fontSize: 15 }}>{value}</p>
      <p style={{ color: C.textMuted, margin: 0, fontSize: 11 }}>{label}</p>
    </div>
  );
}

