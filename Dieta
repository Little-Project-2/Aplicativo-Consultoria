  rateRecipe: async (uid, recipeId, rating, comment = '') => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const ratings = storage.get('fitpro_ratings') || {};
      const key = `${uid}_${recipeId}`;
      ratings[key] = { uid, recipeId, rating, comment, createdAt: new Date().toISOString() };
      storage.set('fitpro_ratings', ratings);
      return ratings[key];
    }
  },

  getRecipeRating: async (uid, recipeId) => {
    if (USE_MOCK) {
      await delay(MOCK_DELAY);
      const ratings = storage.get('fitpro_ratings') || {};
      return ratings[`${uid}_${recipeId}`] || null;
    }
  },
};

