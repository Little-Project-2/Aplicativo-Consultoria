function DailySummaryBar({ log, plan }) {
  if (!plan) return null;
  const { progress } = log;
  const target = plan.targetCalories;
  const pct    = Math.min(Math.round((progress.calories / target) * 100), 100);

  return (
    <div style={styles.summaryBar}>
      <div style={styles.summaryRow}>
        <span style={styles.summaryLabel}>Total: {Math.round(progress.calories)} / {target} kcal</span>
        <span style={{ ...styles.summaryPct, color: pct > 100 ? C.error : C.accent }}>{pct}%</span>
      </div>
      <div style={styles.barTrack}>
        <div style={{
          ...styles.barFill,
          width: `${pct}%`,
          backgroundColor: pct > 100 ? C.error : C.accent,
        }} />
      </div>
      <div style={styles.macrosMini}>
        {[
          { label: 'P', value: progress.protein,  color: C.protein },
          { label: 'C', value: progress.carbs,    color: C.carbs   },
          { label: 'G', value: progress.fat,       color: C.fat     },
        ].map(m => (
          <span key={m.label} style={styles.macroMiniItem}>
            <span style={{ color: m.color, fontWeight: 700 }}>{m.label}:</span>{' '}
            {Math.round(m.value)}g
          </span>
        ))}
      </div>
    </div>
  );
}

