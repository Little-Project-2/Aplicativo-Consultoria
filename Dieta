function StatsPanel({ clients }) {
  const total    = clients.length;
  const goals    = clients.reduce((acc, c) => { acc[c.goal] = (acc[c.goal] || 0) + 1; return acc; }, {});
  const avgWeight= total > 0 ? (clients.reduce((a, c) => a + (c.weight || 0), 0) / total).toFixed(1) : '—';
  const avgAge   = total > 0 ? Math.round(clients.reduce((a, c) => a + (c.age || 0), 0) / total) : '—';

  return (
    <div style={{ padding: '16px' }}>
      <div style={styles.statsGrid}>
        <StatBox label="Total de Clientes" value={total} icon="👥" />
        <StatBox label="Peso Médio"        value={`${avgWeight}kg`} icon="⚖️" />
        <StatBox label="Idade Média"       value={`${avgAge}a`} icon="📅" />
        <StatBox label="Objetivos" value="" icon="🎯"
          extra={Object.entries(goals).map(([k, v]) => `${GOALS[k]?.label}: ${v}`).join('\n')}
        />
      </div>
    </div>
  );
}

