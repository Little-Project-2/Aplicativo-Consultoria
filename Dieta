export const ACTIONS = {
  // Auth
  SET_AUTH_LOADING:    'SET_AUTH_LOADING',
  SET_AUTH_USER:       'SET_AUTH_USER',
  SET_AUTH_ERROR:      'SET_AUTH_ERROR',
  SIGN_OUT:            'SIGN_OUT',

  // Profile
  SET_PROFILE:         'SET_PROFILE',
  UPDATE_PROFILE:      'UPDATE_PROFILE',

  // Nutrition Plan
  SET_NUTRITION_PLAN:  'SET_NUTRITION_PLAN',
  UPDATE_PLAN:         'UPDATE_PLAN',

  // Daily Log
  SET_DAILY_LOG:       'SET_DAILY_LOG',
  ADD_FOOD_TO_MEAL:    'ADD_FOOD_TO_MEAL',
  REMOVE_FOOD:         'REMOVE_FOOD',
  RECALC_PROGRESS:     'RECALC_PROGRESS',

  // UI
  SET_SCREEN:          'SET_SCREEN',
  OPEN_MODAL:          'OPEN_MODAL',
  CLOSE_MODAL:         'CLOSE_MODAL',
  SET_UI_LOADING:      'SET_UI_LOADING',
  SHOW_TOAST:          'SHOW_TOAST',
  CLEAR_TOAST:         'CLEAR_TOAST',
};

// ─────────────────────────────────────────────
// REDUCER
// ─────────────────────────────────────────────

function appReducer(state, action) {
  switch (action.type) {

    // ─ Auth ─
    case ACTIONS.SET_AUTH_LOADING:
      return { ...state, auth: { ...state.auth, isLoading: action.payload } };

    case ACTIONS.SET_AUTH_USER:
      return { ...state, auth: { user: action.payload, isLoading: false, error: null } };

    case ACTIONS.SET_AUTH_ERROR:
      return { ...state, auth: { ...state.auth, isLoading: false, error: action.payload } };

    case ACTIONS.SIGN_OUT:
      return {
        ...initialState,
        ui: { ...initialState.ui, activeScreen: 'onboarding', isLoading: false },
        auth: { user: null, isLoading: false, error: null },
      };

    // ─ Profile ─
    case ACTIONS.SET_PROFILE:
      return { ...state, profile: action.payload };

    case ACTIONS.UPDATE_PROFILE:
      return { ...state, profile: { ...state.profile, ...action.payload } };

    // ─ Nutrition Plan ─
    case ACTIONS.SET_NUTRITION_PLAN:
      return { ...state, nutritionPlan: action.payload };

    case ACTIONS.UPDATE_PLAN:
      return { ...state, nutritionPlan: { ...state.nutritionPlan, ...action.payload } };

    // ─ Daily Log ─
    case ACTIONS.SET_DAILY_LOG:
      return { ...state, dailyLog: { ...state.dailyLog, ...action.payload } };

    case ACTIONS.ADD_FOOD_TO_MEAL: {
      const { mealId, foodEntry } = action.payload;
      const meals = { ...state.dailyLog.meals };
      if (!meals[mealId]) meals[mealId] = { foods: [] };
      meals[mealId] = { ...meals[mealId], foods: [...meals[mealId].foods, foodEntry] };
      const progress = recalcProgress(meals);
      return { ...state, dailyLog: { ...state.dailyLog, meals, progress } };
    }

    case ACTIONS.REMOVE_FOOD: {
      const { mealId, entryId } = action.payload;
      const meals = { ...state.dailyLog.meals };
      if (meals[mealId]) {
        meals[mealId] = {
          ...meals[mealId],
          foods: meals[mealId].foods.filter(f => f.id !== entryId),
        };
      }
      const progress = recalcProgress(meals);
      return { ...state, dailyLog: { ...state.dailyLog, meals, progress } };
    }

    case ACTIONS.RECALC_PROGRESS: {
      const progress = recalcProgress(state.dailyLog.meals);
      return { ...state, dailyLog: { ...state.dailyLog, progress } };
    }

    // ─ UI ─
    case ACTIONS.SET_SCREEN:
      return { ...state, ui: { ...state.ui, activeScreen: action.payload } };

    case ACTIONS.OPEN_MODAL:
      return { ...state, ui: { ...state.ui, activeModal: action.payload.modal, modalData: action.payload.data || null } };

    case ACTIONS.CLOSE_MODAL:
      return { ...state, ui: { ...state.ui, activeModal: null, modalData: null } };

    case ACTIONS.SET_UI_LOADING:
      return { ...state, ui: { ...state.ui, isLoading: action.payload } };

    case ACTIONS.SHOW_TOAST:
      return { ...state, ui: { ...state.ui, toast: action.payload } };

    case ACTIONS.CLEAR_TOAST:
      return { ...state, ui: { ...state.ui, toast: null } };

    default:
      return state;
  }
}

// Helper: recalcula o progresso total do dia
function recalcProgress(meals) {
  return Object.values(meals).reduce((acc, meal) => {
    const foods = meal.foods || [];
    foods.forEach(f => {
      acc.calories += f.macros?.calories || 0;
      acc.protein  += f.macros?.protein  || 0;
      acc.carbs    += f.macros?.carbs    || 0;
      acc.fat      += f.macros?.fat      || 0;
    });
    return acc;
  }, { calories: 0, protein: 0, carbs: 0, fat: 0 });
}

