// ─────────────────────────────────────────────

const STEPS = [
  { id: 1, title: 'Bem-vindo!',        subtitle: 'Vamos começar seu plano personalizado' },
  { id: 2, title: 'Seu Corpo',         subtitle: 'Precisamos desses dados para calcular seus macros' },
