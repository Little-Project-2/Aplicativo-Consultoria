export function formatCalories(kcal) {
  return `${Math.round(kcal)} kcal`;
}

export function getProgressColor(consumed, target) {
  const pct = consumed / target;
  if (pct < 0.5)  return '#60A5FA'; // azul
  if (pct < 0.85) return '#34D399'; // verde
  if (pct < 1.0)  return '#FBBF24'; // amarelo
  if (pct <= 1.1) return '#F97316'; // laranja
  return '#EF4444';                  // vermelho
}

export function calculateDailyProgress(meals) {
  return meals.reduce((acc, meal) => ({
    calories: acc.calories + meal.consumed.calories,
    protein:  acc.protein  + meal.consumed.protein,
    carbs:    acc.carbs    + meal.consumed.carbs,
    fat:      acc.fat      + meal.consumed.fat,
  }), { calories: 0, protein: 0, carbs: 0, fat: 0 });
}
/**
 * FitPro — Algoritmo de Substituição Inteligente de Alimentos
 *
 * Objetivo: trocar um alimento por outro mantendo os macros-alvo.
 * Estratégia: igualar o macro dominante da refeição (carbs, proteína ou gordura).
 */

import { FOODS, getFoodById, filterFoodsByRestrictions, calculateFoodMacros } from '../data/foodDatabase';

// ─────────────────────────────────────────────
// TIPOS DE SUBSTITUIÇÃO
// ─────────────────────────────────────────────

/**
 * Macro dominante de um alimento
 */
function getDominantMacro(food) {
  const kcalProtein = food.protein * 4;
  const kcalCarbs   = food.carbs   * 4;
  const kcalFat     = food.fat     * 9;
  const total       = kcalProtein + kcalCarbs + kcalFat;
  if (total === 0) return 'calories';

  if (kcalProtein >= kcalCarbs && kcalProtein >= kcalFat) return 'protein';
  if (kcalCarbs   >= kcalProtein && kcalCarbs >= kcalFat) return 'carbs';
  return 'fat';
}

/**
 * Pontua um alimento candidato como substituto
 * Quanto menor o score, melhor o match
 */
function scoreSimilarity(original, candidate, targetGrams) {
  const origMacros = calculateFoodMacros(original, targetGrams);

  // Calcula gramas necessárias para igualar o macro dominante
  const dominant = getDominantMacro(original);
  const targetValue = origMacros[dominant];

  let candidateGrams;
  const candidateMacroPer100 = candidate[dominant];
  if (candidateMacroPer100 === 0) return Infinity;

  candidateGrams = (targetValue / candidateMacroPer100) * 100;
  const candidateMacros = calculateFoodMacros(candidate, candidateGrams);

  // Diferença percentual em calorias e macros secundários
  const calDiff      = Math.abs(candidateMacros.calories - origMacros.calories) / origMacros.calories;
  const proteinDiff  = Math.abs(candidateMacros.protein  - origMacros.protein)  / Math.max(origMacros.protein, 1);
  const carbsDiff    = Math.abs(candidateMacros.carbs    - origMacros.carbs)    / Math.max(origMacros.carbs,   1);
  const fatDiff      = Math.abs(candidateMacros.fat      - origMacros.fat)      / Math.max(origMacros.fat,     1);

  // Penalizar diferença calórica mais pesado
  const score = (calDiff * 2) + proteinDiff + carbsDiff + fatDiff;

  return { score, candidateGrams: Math.round(candidateGrams), candidateMacros };
}

// ─────────────────────────────────────────────
// FUNÇÃO PRINCIPAL DE SUBSTITUIÇÃO
// ─────────────────────────────────────────────

/**
 * Encontra os melhores substitutos para um alimento
 *
 * @param {string}   foodId         - ID do alimento a substituir
 * @param {number}   currentGrams   - quantidade atual em gramas
 * @param {Object}   [restrictions] - restrições alimentares do usuário
 * @param {number}   [maxResults]   - max de opções retornadas (padrão: 5)
 * @returns {SubstitutionResult[]}
 */
export function findSubstitutes(foodId, currentGrams, restrictions = {}, maxResults = 5) {
  const original = getFoodById(foodId);
  if (!original) return [];

  // Pool de candidatos: mesma categoria + substitutos declarados + alimentos da mesma categoria
  const explicitSubIds = original.substitutes || [];
  const sameCategoryFoods = FOODS.filter(f =>
    f.id !== foodId &&
    f.category === original.category
  );
  const explicitFoods = explicitSubIds
    .map(id => getFoodById(id))
    .filter(Boolean);

  // União sem duplicatas
  const candidates = [...new Map(
    [...explicitFoods, ...sameCategoryFoods].map(f => [f.id, f])
  ).values()];

  // Filtrar por restrições
  const compatible = filterFoodsByRestrictions(candidates, restrictions);

  // Pontuar e ordenar
  const scored = compatible
    .map(candidate => {
      const result = scoreSimilarity(original, candidate, currentGrams);
      if (result === Infinity || result.score === undefined) return null;
      return {
        food:         candidate,
        gramsNeeded:  result.candidateGrams,
        macros:       result.candidateMacros,
        score:        result.score,
        matchQuality: getMatchQuality(result.score),
      };
    })
    .filter(Boolean)
    .sort((a, b) => a.score - b.score)
    .slice(0, maxResults);

  return scored;
}

function getMatchQuality(score) {
  if (score < 0.1)  return { label: 'Excelente', color: '#34D399', icon: '🌟' };
  if (score < 0.25) return { label: 'Ótimo',     color: '#60A5FA', icon: '✅' };
  if (score < 0.5)  return { label: 'Bom',       color: '#FBBF24', icon: '👍' };
  if (score < 0.8)  return { label: 'Regular',   color: '#F97316', icon: '⚠️' };
  return                    { label: 'Diferente', color: '#EF4444', icon: '🔄' };
}

// ─────────────────────────────────────────────
// SUBSTITUIÇÃO POR MACRO ESPECÍFICO
// ─────────────────────────────────────────────

/**
 * Calcula quanto de B precisa para igualar X gramas de macro de A
 *
 * Exemplo: igualar 40g de carbo de arroz usando batata doce
 *
 * @param {string} fromFoodId
 * @param {number} fromGrams
 * @param {string} toFoodId
 * @param {'protein'|'carbs'|'fat'|'calories'} macro
 * @returns {{ grams: number, macros: Object } | null}
 */
export function calculateEquivalentGrams(fromFoodId, fromGrams, toFoodId, macro = 'carbs') {
  const from = getFoodById(fromFoodId);
  const to   = getFoodById(toFoodId);
  if (!from || !to) return null;

  const fromMacros = calculateFoodMacros(from, fromGrams);
  const targetValue = fromMacros[macro];

  const toMacroPer100 = to[macro];
  if (toMacroPer100 === 0) return null;

  const equivalentGrams = (targetValue / toMacroPer100) * 100;
  const equivalentMacros = calculateFoodMacros(to, equivalentGrams);

  return {
    grams:  Math.round(equivalentGrams),
    macros: equivalentMacros,
    difference: {
      calories: Math.round(equivalentMacros.calories - fromMacros.calories),
      protein:  parseFloat((equivalentMacros.protein  - fromMacros.protein).toFixed(1)),
      carbs:    parseFloat((equivalentMacros.carbs    - fromMacros.carbs).toFixed(1)),
      fat:      parseFloat((equivalentMacros.fat      - fromMacros.fat).toFixed(1)),
    },
  };
}

// ─────────────────────────────────────────────
// SUBSTITUIÇÃO DE REFEIÇÃO COMPLETA
// ─────────────────────────────────────────────

/**
 * Sugere refeições alternativas de um receituário para manter macros próximos
 *
 * @param {Object}   targetMacros  - { calories, protein, carbs, fat }
 * @param {Object[]} recipes       - lista de receitas
 * @param {Object}   [restrictions]
 * @param {number}   [tolerance]   - tolerância percentual (padrão 0.15 = 15%)
 * @returns {Object[]} receitas compatíveis, ordenadas por proximidade
 */
export function findCompatibleRecipes(targetMacros, recipes, restrictions = {}, tolerance = 0.15) {
  return recipes
    .filter(recipe => {
      // Verificar restrições
      if (restrictions.lactoseIntolerance && recipe.containsLactose)  return false;
      if (restrictions.glutenIntolerance  && recipe.containsGluten)   return false;
      if (restrictions.vegan              && !recipe.isVegan)          return false;
      if (restrictions.vegetarian         && !recipe.isVegetarian && !recipe.isVegan) return false;
      return true;
    })
    .map(recipe => {
      const calDiff  = Math.abs(recipe.macros.calories - targetMacros.calories) / targetMacros.calories;
      const protDiff = Math.abs(recipe.macros.protein  - targetMacros.protein)  / Math.max(targetMacros.protein, 1);
      const carbDiff = Math.abs(recipe.macros.carbs    - targetMacros.carbs)    / Math.max(targetMacros.carbs, 1);
      const fatDiff  = Math.abs(recipe.macros.fat      - targetMacros.fat)      / Math.max(targetMacros.fat, 1);

      const avgDiff = (calDiff + protDiff + carbDiff + fatDiff) / 4;
      return { ...recipe, matchScore: avgDiff, calDiff, protDiff, carbDiff, fatDiff };
    })
    .filter(r => r.calDiff <= tolerance && r.protDiff <= (tolerance * 1.5))
    .sort((a, b) => a.matchScore - b.matchScore);
}
