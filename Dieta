function AddFoodModal({ mealName, restrictions, onAdd, onClose }) {
  const [query, setQuery] = useState('');
  const [selected, setSelected] = useState(null);
  const [grams, setGrams] = useState('100');
  const [category, setCategory] = useState('all');

  const results = useMemo(() => {
    let pool = query.length >= 2 ? searchFoods(query) : FOODS;
    if (category !== 'all') pool = pool.filter(f => f.category === category);
    return filterFoodsByRestrictions(pool, restrictions).slice(0, 30);
  }, [query, category, restrictions]);

  const preview = useMemo(() => {
    if (!selected || !grams) return null;
    return calculateFoodMacros(selected, parseFloat(grams) || 100);
  }, [selected, grams]);

  return (
    <div style={styles.overlay}>
      <div style={styles.modal}>
        <div style={styles.modalHeader}>
          <h2 style={styles.modalTitle}>Adicionar a {mealName}</h2>
