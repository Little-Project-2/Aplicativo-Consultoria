// CARD DE RECEITA (GRID)
// ─────────────────────────────────────────────

function RecipeCard({ recipe, onClick }) {
  const cat = RECIPE_CATEGORIES[recipe.category];
  return (
    <button onClick={onClick} style={styles.recipeCard}>
      <div style={styles.recipeCardImg}>
        <span style={{ fontSize: 40 }}>{cat?.icon || '🍽️'}</span>
      </div>
      <div style={styles.recipeCardBody}>
        <p style={styles.recipeCardName}>{recipe.name}</p>
        <div style={styles.recipeCardTags}>
          {recipe.isVegan && <span style={styles.tag}>🌱</span>}
          {!recipe.containsGluten && <span style={styles.tag}>GF</span>}
          {!recipe.containsLactose && <span style={styles.tag}>SL</span>}
        </div>
        <div style={styles.recipeCardMacros}>
          <MacroBit label="Kcal" value={recipe.macros.calories} color={C.text} />
          <MacroBit label="P" value={`${recipe.macros.protein}g`} color={C.protein} />
          <MacroBit label="C" value={`${recipe.macros.carbs}g`}   color={C.carbs} />
          <MacroBit label="G" value={`${recipe.macros.fat}g`}     color={C.fat} />
        </div>
        <div style={styles.recipeCardFooter}>
          <span style={styles.recipeTime}>⏱ {recipe.prepTime + recipe.cookTime}min</span>
          <StarRating rating={recipe.rating} count={recipe.ratingCount} />
        </div>
      </div>
    </button>
  );
}

// ─────────────────────────────────────────────
// ITEM DE RECEITA (LIST)
// ─────────────────────────────────────────────

function RecipeListItem({ recipe, onClick }) {
  const cat = RECIPE_CATEGORIES[recipe.category];
  return (
    <button onClick={onClick} style={styles.listItem}>
      <div style={styles.listItemIcon}>
        <span style={{ fontSize: 28 }}>{cat?.icon || '🍽️'}</span>
      </div>
      <div style={styles.listItemContent}>
        <p style={styles.listItemName}>{recipe.name}</p>
        <p style={styles.listItemMeta}>
          {recipe.macros.calories} kcal · P:{recipe.macros.protein}g · C:{recipe.macros.carbs}g · G:{recipe.macros.fat}g
        </p>
        <div style={{ display: 'flex', gap: 8, marginTop: 4 }}>
          <span style={styles.listItemTime}>⏱ {recipe.prepTime + recipe.cookTime}min</span>
          <StarRating rating={recipe.rating} count={recipe.ratingCount} small />
        </div>
      </div>
      <span style={{ color: C.textMuted, fontSize: 18 }}>›</span>
    </button>
  );
}

// ─────────────────────────────────────────────
// DETALHE DA RECEITA
// ─────────────────────────────────────────────

function RecipeDetail({ recipe, plan, restrictions, onBack, onRate, showToast }) {
  const cat = RECIPE_CATEGORIES[recipe.category];
  const [activeTab, setActiveTab] = useState('ingredients'); // ingredients | steps | alternatives

  // Receitas alternativas com macros similares
  const alternatives = useMemo(() => {
    if (!plan) return [];
    return findCompatibleRecipes(recipe.macros, RECIPES.filter(r => r.id !== recipe.id), restrictions, 0.20);
  }, [recipe, plan, restrictions]);

  return (
    <div style={styles.container}>
      {/* Hero */}
      <div style={styles.detailHero}>
        <button onClick={onBack} style={styles.detailBack}>←</button>
        <div style={styles.heroIcon}>{cat?.icon || '🍽️'}</div>
        <div style={styles.heroOverlay}>
          <div style={styles.heroBadge}>{cat?.label}</div>
          <h1 style={styles.heroTitle}>{recipe.name}</h1>
          <div style={styles.heroMeta}>
            <span style={styles.heroMetaItem}>⏱ {recipe.prepTime + recipe.cookTime}min</span>
            <span style={styles.heroMetaItem}>👤 {recipe.servings} porção</span>
            <span style={styles.heroMetaItem}>📊 {recipe.difficulty}</span>
          </div>
          <StarRating rating={recipe.rating} count={recipe.ratingCount} />
        </div>
      </div>

      {/* Macros Overview */}
      <div style={styles.macrosOverview}>
        {[
          { label: 'Calorias', value: recipe.macros.calories, unit: 'kcal', color: C.text },
          { label: 'Proteína', value: `${recipe.macros.protein}g`, color: C.protein },
          { label: 'Carbs',    value: `${recipe.macros.carbs}g`,   color: C.carbs },
          { label: 'Gordura',  value: `${recipe.macros.fat}g`,     color: C.fat },
        ].map(m => (
          <div key={m.label} style={styles.macroOverviewItem}>
            <span style={{ ...styles.macroOverviewValue, color: m.color }}>{m.value}</span>
            <span style={styles.macroOverviewLabel}>{m.label}</span>
          </div>
        ))}
      </div>

      {/* Badges de restrições */}
      <div style={styles.badgesRow}>
        {recipe.isVegan        && <RestrictionBadge icon="🌱" label="Vegano" />}
        {recipe.isVegetarian   && <RestrictionBadge icon="🥦" label="Vegetariano" />}
        {!recipe.containsGluten  && <RestrictionBadge icon="🌾" label="Sem Glúten" />}
        {!recipe.containsLactose && <RestrictionBadge icon="🥛" label="Sem Lactose" />}
      </div>

      {/* Tabs */}
      <div style={styles.tabs}>
        {[
          { id: 'ingredients', label: '🥕 Ingredientes' },
          { id: 'steps',       label: '👨‍🍳 Preparo' },
          { id: 'alternatives',label: `🔄 Alternativas (${alternatives.length})` },
        ].map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id)}
            style={{ ...styles.tab, ...(activeTab === tab.id ? styles.tabActive : {}) }}
          >
            {tab.label}
          </button>
        ))}
      </div>

      {/* Conteúdo da tab */}
      <div style={styles.detailScroll}>
        {activeTab === 'ingredients' && (
          <div style={styles.tabContent}>
            {recipe.ingredients.map((ing, i) => (
              <div key={i} style={styles.ingredientRow}>
                <div style={styles.ingredientBullet} />
                <span style={styles.ingredientName}>{ing.name}</span>
                <span style={styles.ingredientAmount}>{ing.amount} {ing.unit}</span>
              </div>
            ))}
          </div>
        )}

        {activeTab === 'steps' && (
          <div style={styles.tabContent}>
            {recipe.steps.map((step, i) => (
              <div key={i} style={styles.stepRow}>
                <div style={styles.stepNumber}>{i + 1}</div>
                <p style={styles.stepText}>{step}</p>
              </div>
            ))}
          </div>
        )}

        {activeTab === 'alternatives' && (
          <div style={styles.tabContent}>
            {alternatives.length === 0 ? (
              <p style={{ color: C.textMuted, textAlign: 'center', padding: 20 }}>
                Nenhuma alternativa próxima encontrada nos macros.
              </p>
            ) : (
              <>
                <p style={styles.altInfo}>
                  Receitas com macros similares que você pode usar como substituição:
                </p>
                {alternatives.map(alt => (
                  <div key={alt.id} style={styles.altCard}>
                    <div style={styles.altCardHeader}>
                      <p style={styles.altCardName}>{alt.name}</p>
                      <span style={styles.altMatchBadge}>
                        ≈{Math.round((1 - alt.matchScore) * 100)}% match
                      </span>
                    </div>
                    <p style={styles.altCardMeta}>
                      {alt.macros.calories} kcal · P:{alt.macros.protein}g · C:{alt.macros.carbs}g · G:{alt.macros.fat}g
                    </p>
                    <div style={styles.altDiff}>
                      {alt.calDiff < 0.05 && <span style={styles.altGood}>✅ Calorias muito próximas</span>}
                      {alt.protDiff < 0.1  && <span style={styles.altGood}>✅ Proteína próxima</span>}
                    </div>
                  </div>
                ))}
              </>
            )}
          </div>
        )}
        <div style={{ height: 100 }} />
      </div>

      {/* CTA Rate */}
      <div style={styles.detailFooter}>
        <button onClick={onRate} style={styles.rateBtn}>
          ⭐ Avaliar Receita
        </button>
        <button
          onClick={() => showToast({ message: '📌 Receita salva nos favoritos!', type: 'success' })}
          style={styles.saveBtn}
        >
          🔖 Salvar
        </button>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────
// MODAL DE AVALIAÇÃO
// ─────────────────────────────────────────────

function RatingModal({ recipeId, recipeName, onSubmit, onClose }) {
  const [rating, setRating] = useState(5);
  const [hunger, setHunger] = useState(3);
  const [adherence, setAdherence] = useState(3);
  const [comment, setComment] = useState('');

  return (
    <div style={styles.overlay}>
      <div style={styles.ratingModal}>
        <div style={styles.modalHeader}>
          <h2 style={styles.modalTitle}>Avaliar Receita</h2>
          <button onClick={onClose} style={styles.closeBtn}>✕</button>
        </div>
        <p style={styles.ratingRecipeName}>{recipeName}</p>

        {/* Estrelas */}
        <div style={styles.ratingSection}>
          <label style={styles.ratingLabel}>Nota geral</label>
          <div style={styles.starsRow}>
            {[1,2,3,4,5].map(s => (
              <button key={s} onClick={() => setRating(s)} style={styles.starBtn}>
                <span style={{ fontSize: 28, color: s <= rating ? '#F59E0B' : C.border }}>★</span>
              </button>
            ))}
          </div>
        </div>

        {/* Escala de fome */}
        <div style={styles.ratingSection}>
          <label style={styles.ratingLabel}>
            Sensação de saciedade — {hunger === 1 ? 'Com muita fome' : hunger === 5 ? 'Satisfeito' : `${hunger}/5`}
          </label>
          <input type="range" min={1} max={5} value={hunger}
            onChange={e => setHunger(+e.target.value)} style={styles.rangeInput} />
          <div style={styles.rangeLabels}>
            <span>😰 Fome</span><span>😊 Saciado</span>
          </div>
        </div>

        {/* Escala de adesão */}
        <div style={styles.ratingSection}>
          <label style={styles.ratingLabel}>
            Facilidade de preparo — {adherence}/5
          </label>
          <input type="range" min={1} max={5} value={adherence}
            onChange={e => setAdherence(+e.target.value)} style={styles.rangeInput} />
          <div style={styles.rangeLabels}>
            <span>😓 Difícil</span><span>😄 Fácil</span>
          </div>
        </div>

        {/* Comentário */}
        <div style={styles.ratingSection}>
          <label style={styles.ratingLabel}>Comentário (opcional)</label>
          <textarea
            style={styles.commentInput}
            placeholder="O que achou da receita?"
            value={comment}
            onChange={e => setComment(e.target.value)}
            rows={3}
          />
        </div>

        <button
          onClick={() => onSubmit(recipeId, rating, comment)}
          style={styles.submitRatingBtn}
        >
          ⭐ Enviar Avaliação
        </button>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────
// COMPONENTES AUXILIARES
// ─────────────────────────────────────────────

function StarRating({ rating, count, small }) {
  return (
    <div style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
      <span style={{ color: '#F59E0B', fontSize: small ? 11 : 12 }}>
        {'★'.repeat(Math.round(rating))}{'☆'.repeat(5 - Math.round(rating))}
      </span>
      <span style={{ fontSize: 11, color: C.textMuted }}>{rating} ({count})</span>
    </div>
  );
}

function MacroBit({ label, value, color }) {
  return (
    <div style={{ textAlign: 'center' }}>
      <p style={{ margin: 0, fontWeight: 700, fontSize: 13, color }}>{value}</p>
      <p style={{ margin: 0, fontSize: 10, color: C.textMuted }}>{label}</p>
    </div>
  );
}

function RestrictionBadge({ icon, label }) {
  return (
    <span style={styles.restrictionBadge}>{icon} {label}</span>
  );
}

