function FeedbackTab({ uid, showToast }) {
  const [hunger, setHunger]       = useState(3);
  const [adherence, setAdherence] = useState(3);
  const [energy, setEnergy]       = useState(3);
  const [comment, setComment]     = useState('');
  const [submitted, setSubmitted] = useState(false);
  const [submitting, setSubmitting] = useState(false);

  const handleSubmit = useCallback(async () => {
    setSubmitting(true);
    try {
      await feedbackService.submitFeedback(uid, {
        type: 'daily_feedback',
        hunger,
        adherence,
        energy,
        comment,
        date: getTodayKey(),
      });
      setSubmitted(true);
      showToast({ message: '⭐ Feedback enviado ao profissional!', type: 'success' });
    } catch (e) {
      showToast({ message: 'Erro ao enviar feedback.', type: 'error' });
    } finally {
      setSubmitting(false);
    }
  }, [uid, hunger, adherence, energy, comment, showToast]);

  if (submitted) {
    return (
      <div style={{ ...styles.tabContent, textAlign: 'center', paddingTop: 40 }}>
        <p style={{ fontSize: 56 }}>✅</p>
        <h3 style={{ color: C.accent, margin: '12px 0 8px' }}>Feedback enviado!</h3>
        <p style={{ color: C.textMuted, fontSize: 14 }}>
          Seu profissional receberá suas avaliações e poderá ajustar o plano.
        </p>
        <button onClick={() => setSubmitted(false)} style={styles.resetBtn}>
          Enviar outro
        </button>
      </div>
    );
  }

  return (
    <div style={styles.tabContent}>
      <p style={styles.feedbackIntro}>
        📝 Envie seu feedback diário para que o profissional possa ajustar seu plano.
      </p>

      <FeedbackScale
        label="😰 Como está sua fome ao longo do dia?"
        value={hunger}
        onChange={setHunger}
        leftLabel="Muita fome"
        rightLabel="Saciado"
      />

      <FeedbackScale
        label="📋 Como está sua adesão ao plano?"
        value={adherence}
        onChange={setAdherence}
        leftLabel="Difícil seguir"
        rightLabel="Seguindo 100%"
      />

      <FeedbackScale
        label="⚡ Como está seu nível de energia?"
        value={energy}
        onChange={setEnergy}
        leftLabel="Sem energia"
        rightLabel="Cheio de energia"
      />

      <div style={styles.feedbackField}>
        <label style={styles.feedbackLabel}>
          💬 Comentário adicional (opcional)
        </label>
        <textarea
          style={styles.feedbackTextarea}
          value={comment}
          onChange={e => setComment(e.target.value)}
          placeholder="Conte algo sobre seu dia, como se sentiu, dificuldades..."
          rows={4}
        />
      </div>

      <button
        onClick={handleSubmit}
        disabled={submitting}
        style={{ ...styles.submitBtn, opacity: submitting ? 0.6 : 1 }}
      >
        {submitting ? '⏳ Enviando...' : '📤 Enviar Feedback'}
      </button>
    </div>
  );
}

