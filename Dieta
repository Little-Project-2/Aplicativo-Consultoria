/**
 * FitPro — Componentes Compartilhados
 * BottomNav, Toast, Spinner, Modal genérico
 */

import React, { useEffect } from 'react';
import { useUI, useActions } from '../context/AppContext';

const C = {
  bg: '#0A0F1E', surface: '#111827', card: '#1F2937', border: '#374151',
  accent: '#00FF94', text: '#F9FAFB', textMuted: '#9CA3AF',
  error: '#EF4444', warning: '#F59E0B', blue: '#60A5FA',
  success: '#34D399',
};

// ─────────────────────────────────────────────
// BOTTOM NAVIGATION
// ─────────────────────────────────────────────

const NAV_ITEMS = [
  { id: 'dashboard', icon: '🏠', label: 'Início'    },
  { id: 'meals',     icon: '🍽️', label: 'Refeições' },
  { id: 'recipes',   icon: '📖', label: 'Receitas'  },
  { id: 'profile',   icon: '👤', label: 'Perfil'    },
];

export function BottomNav() {
  const { activeScreen } = useUI();
  const { navigate } = useActions();

  // Mostrar apenas nas telas principais
  const showNav = ['dashboard', 'meals', 'recipes', 'profile'].includes(activeScreen);
  if (!showNav) return null;

  return (
    <nav style={styles.nav}>
      {NAV_ITEMS.map(item => {
        const isActive = activeScreen === item.id;
        return (
          <button
            key={item.id}
            onClick={() => navigate(item.id)}
            style={styles.navBtn}
          >
            <span style={{ fontSize: 22 }}>{item.icon}</span>
            <span style={{
              ...styles.navLabel,
              color: isActive ? C.accent : C.textMuted,
              fontWeight: isActive ? 700 : 400,
            }}>
              {item.label}
            </span>
            {isActive && <div style={styles.navDot} />}
          </button>
        );
      })}
    </nav>
  );
}

// ─────────────────────────────────────────────
// TOAST / NOTIFICAÇÃO
// ─────────────────────────────────────────────

export function Toast() {
  const { toast } = useUI();
  const { clearToast } = useActionsWithClear();

  if (!toast) return null;

  const bgColor =
    toast.type === 'success' ? C.success :
    toast.type === 'error'   ? C.error   :
    toast.type === 'warning' ? C.warning :
    C.blue;

  return (
    <div style={{
      ...styles.toast,
      backgroundColor: bgColor,
    }}>
      <p style={styles.toastText}>{toast.message}</p>
    </div>
  );
}

function useActionsWithClear() {
  const { dispatch } = require('../context/AppContext').useApp();
  const { ACTIONS } = require('../context/AppContext');
  return {
    clearToast: () => dispatch({ type: ACTIONS?.CLEAR_TOAST }),
  };
}

