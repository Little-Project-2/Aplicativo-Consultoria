/**
 * FitPro — Painel do Profissional
 * Visualiza lista de clientes, edita planos, ajusta macros e estratégia nutricional
 */

import React, { useState, useEffect, useCallback } from 'react';
import { useAuth, useActions } from '../context/AppContext';
import { userService, nutritionService, feedbackService } from '../services/firebase';
import { GOALS, ACTIVITY_FACTORS } from '../utils/calculations';

const C = {
  bg: '#0A0F1E', surface: '#111827', card: '#1F2937', border: '#374151',
  accent: '#00FF94', text: '#F9FAFB', textMuted: '#9CA3AF',
  error: '#EF4444', warning: '#F59E0B', blue: '#60A5FA',
  protein: '#EF4444', carbs: '#F59E0B', fat: '#8B5CF6',
};

// ─────────────────────────────────────────────
// PAINEL PRINCIPAL
// ─────────────────────────────────────────────

export default function ProfessionalScreen() {
  const auth = useAuth();
  const { navigate, signOut, showToast } = useActions();

  const [clients, setClients] = useState([]);
  const [loading, setLoading] = useState(true);
  const [selected, setSelected] = useState(null); // cliente selecionado
  const [tab, setTab] = useState('clients');        // clients | feedbacks | stats

  // Carregar clientes
  useEffect(() => {
    const load = async () => {
      try {
        const list = await userService.getAllClients(auth.user?.uid);
        setClients(list || []);
      } catch (e) {
        console.error(e);
      } finally {
        setLoading(false);
      }
    };
    if (auth.user?.uid) load();
  }, [auth.user?.uid]);

  if (selected) {
    return (
      <ClientDetail
        client={selected}
        profUid={auth.user?.uid}
        onBack={() => setSelected(null)}
        showToast={showToast}
      />
    );
  }

  return (
    <div style={styles.container}>
      {/* Header */}
      <div style={styles.header}>
        <div>
          <p style={styles.headerSub}>Painel do Profissional</p>
          <h1 style={styles.headerTitle}>Olá, Dr(a). 👋</h1>
        </div>
        <button onClick={signOut} style={styles.signOutBtn}>Sair</button>
      </div>

      {/* Tabs */}
      <div style={styles.tabs}>
        {[
          { id: 'clients',   label: `👥 Clientes (${clients.length})` },
          { id: 'feedbacks', label: '⭐ Feedbacks' },
          { id: 'stats',     label: '📊 Estatísticas' },
        ].map(t => (
          <button key={t.id} onClick={() => setTab(t.id)}
            style={{ ...styles.tab, ...(tab === t.id ? styles.tabActive : {}) }}>
            {t.label}
          </button>
        ))}
      </div>

      <div style={styles.scroll}>
        {tab === 'clients' && (
          <ClientsList
            clients={clients}
            loading={loading}
            onSelect={setSelected}
          />
        )}
        {tab === 'feedbacks' && <FeedbacksPanel profUid={auth.user?.uid} />}
        {tab === 'stats' && <StatsPanel clients={clients} />}
        <div style={{ height: 80 }} />
      </div>
    </div>
  );
}

