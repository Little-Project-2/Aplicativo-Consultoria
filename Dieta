function ClientDetail({ client, profUid, onBack, showToast }) {
  const [plan, setPlan]   = useState(null);
  const [loading, setLoading] = useState(true);
  const [editMode, setEditMode] = useState(false);
  const [editData, setEditData] = useState({});
  const [saving, setSaving] = useState(false);
  const [feedbacks, setFeedbacks] = useState([]);

  useEffect(() => {
    const load = async () => {
      try {
        const [p, fb] = await Promise.all([
          nutritionService.getPlan(client.uid),
          feedbackService.getFeedbacks(client.uid),
        ]);
        setPlan(p);
        setFeedbacks(fb || []);
        if (p) {
          setEditData({
            targetCalories: p.targetCalories,
            proteinG:       p.macros?.protein?.g,
            carbsG:         p.macros?.carbs?.g,
            fatG:           p.macros?.fat?.g,
            goal:           client.goal,
            activityLevel:  client.activityLevel,
            notes:          p.professionalNotes || '',
          });
        }
      } catch (e) { console.error(e); }
      finally { setLoading(false); }
    };
    load();
  }, [client.uid]);

  const handleSave = async () => {
    setSaving(true);
    try {
      const updates = {
        targetCalories: parseInt(editData.targetCalories),
        macros: {
          ...plan.macros,
          protein: { ...plan.macros.protein, g: parseInt(editData.proteinG) },
          carbs:   { ...plan.macros.carbs,   g: parseInt(editData.carbsG) },
          fat:     { ...plan.macros.fat,     g: parseInt(editData.fatG) },
        },
        professionalNotes: editData.notes,
        updatedAt: new Date().toISOString(),
      };
      await nutritionService.updatePlanByProfessional(client.uid, updates, profUid);
      setPlan(prev => ({ ...prev, ...updates }));
      setEditMode(false);
      showToast({ message: '✅ Plano do cliente atualizado!', type: 'success' });
    } catch (e) {
      showToast({ message: e.message, type: 'error' });
    } finally {
      setSaving(false);
    }
  };

  if (loading) return (
    <div style={{ ...styles.container, alignItems: 'center', justifyContent: 'center' }}>
      <p style={{ color: C.textMuted }}>Carregando dados...</p>
    </div>
  );

  return (
    <div style={styles.container}>
      {/* Header */}
      <div style={styles.header}>
        <button onClick={onBack} style={styles.backBtn}>←</button>
        <h1 style={styles.headerTitle}>{client.name || 'Cliente'}</h1>
        <button onClick={() => setEditMode(e => !e)} style={styles.editToggle}>
          {editMode ? '✕' : '✏️'}
        </button>
      </div>

      <div style={styles.scroll}>
        {/* Perfil resumido */}
        <div style={styles.clientProfileCard}>
          <div style={styles.profileRow}>
            <InfoPill label="Idade"   value={`${client.age}a`} />
            <InfoPill label="Peso"    value={`${client.weight}kg`} />
            <InfoPill label="Altura"  value={`${client.height}cm`} />
            <InfoPill label="IMC"     value={plan?.bmi?.value || '—'} />
          </div>
          <div style={{ ...styles.profileRow, marginTop: 8 }}>
            <InfoPill label="TMB"   value={`${plan?.bmr || '—'} kcal`} />
            <InfoPill label="TDEE"  value={`${plan?.tdee || '—'} kcal`} />
            <InfoPill label="Meta"  value={`${plan?.targetCalories || '—'} kcal`} />
          </div>
          <div style={{ marginTop: 10, padding: '8px 0', borderTop: `1px solid ${C.border}` }}>
            <p style={styles.profileDetailItem}>
              🎯 Objetivo: <strong>{GOALS[client.goal]?.label || '—'}</strong>
            </p>
            <p style={styles.profileDetailItem}>
              ⚡ Atividade: <strong>{ACTIVITY_FACTORS[client.activityLevel]?.label || '—'}</strong>
            </p>
            <p style={styles.profileDetailItem}>
              🍽️ Refeições: <strong>{client.mealCount || 4}x/dia</strong>
            </p>
          </div>
        </div>

        {/* Restrições */}
        {client.restrictions && (
          <div style={styles.section}>
            <h3 style={styles.sectionTitle}>⚠️ Restrições e Condições</h3>
            <div style={styles.restrictionsList}>
              {Object.entries(client.restrictions)
                .filter(([, v]) => v)
                .map(([k]) => (
                  <span key={k} style={styles.restrictionTag}>
                    {k === 'lactoseIntolerance' ? '🥛 Lactose'
                     : k === 'glutenIntolerance' ? '🌾 Glúten'
                     : k === 'diabetes' ? '💉 Diabetes'
                     : k === 'vegan' ? '🌱 Vegano'
                     : k === 'hypertension' ? '❤️ Hipertensão'
                     : k}
                  </span>
                ))
              }
              {client.otherConditions && (
                <p style={styles.otherConditions}>Outras: {client.otherConditions}</p>
              )}
            </div>
          </div>
        )}

        {/* Plano / Edição */}
        {plan && (
          <div style={styles.section}>
            <h3 style={styles.sectionTitle}>📊 Plano Nutricional</h3>

            {editMode ? (
              <div style={styles.editForm}>
                <EditField
                  label="Meta Calórica (kcal)"
                  value={editData.targetCalories}
                  onChange={v => setEditData(p => ({ ...p, targetCalories: v }))}
                  type="number"
                />
                <EditField
                  label="Proteína (g)"
                  value={editData.proteinG}
                  onChange={v => setEditData(p => ({ ...p, proteinG: v }))}
                  type="number"
                />
                <EditField
                  label="Carboidratos (g)"
                  value={editData.carbsG}
                  onChange={v => setEditData(p => ({ ...p, carbsG: v }))}
                  type="number"
                />
                <EditField
                  label="Gordura (g)"
                  value={editData.fatG}
                  onChange={v => setEditData(p => ({ ...p, fatG: v }))}
                  type="number"
                />

                <div style={styles.editField}>
                  <label style={styles.editLabel}>Objetivo</label>
                  <select
                    value={editData.goal}
                    onChange={e => setEditData(p => ({ ...p, goal: e.target.value }))}
                    style={styles.editSelect}
                  >
                    {Object.entries(GOALS).map(([k, v]) => (
                      <option key={k} value={k}>{v.label}</option>
                    ))}
                  </select>
                </div>

                <div style={styles.editField}>
                  <label style={styles.editLabel}>Notas do Profissional</label>
                  <textarea
                    style={styles.editTextarea}
                    value={editData.notes}
                    onChange={e => setEditData(p => ({ ...p, notes: e.target.value }))}
                    placeholder="Orientações específicas para este cliente..."
                    rows={4}
                  />
                </div>

                {/* Alerta de consistência */}
                {(() => {
                  const totalKcal = (parseInt(editData.proteinG) * 4) + (parseInt(editData.carbsG) * 4) + (parseInt(editData.fatG) * 9);
                  const diff = Math.abs(totalKcal - parseInt(editData.targetCalories));
                  if (diff > 50) return (
                    <div style={styles.alertBox}>
                      <p style={styles.alertText}>
                        ⚠️ Os macros somam {totalKcal} kcal vs meta de {editData.targetCalories} kcal
                        (diferença de {diff} kcal). Ajuste para consistência.
                      </p>
                    </div>
                  );
                  return null;
                })()}

                <div style={styles.editActions}>
                  <button onClick={() => setEditMode(false)} style={styles.cancelBtn}>
                    Cancelar
                  </button>
                  <button onClick={handleSave} disabled={saving} style={styles.saveBtn}>
                    {saving ? 'Salvando...' : '✓ Salvar Alterações'}
                  </button>
                </div>
              </div>
            ) : (
              <div style={styles.planDisplay}>
                <PlanRow label="Meta Calórica" value={`${plan.targetCalories} kcal`} />
                <PlanRow label="Proteína"       value={`${plan.macros?.protein?.g}g (${plan.macros?.protein?.percent}%)`} color={C.protein} />
                <PlanRow label="Carboidratos"   value={`${plan.macros?.carbs?.g}g (${plan.macros?.carbs?.percent}%)`} color={C.carbs} />
                <PlanRow label="Gordura"        value={`${plan.macros?.fat?.g}g (${plan.macros?.fat?.percent}%)`} color={C.fat} />
                <PlanRow label="Água"           value={`${(plan.waterMl / 1000).toFixed(1)} L/dia`} color={C.blue} />
                {plan.professionalNotes && (
                  <div style={styles.notesBox}>
                    <p style={styles.notesLabel}>📝 Suas notas:</p>
                    <p style={styles.notesText}>{plan.professionalNotes}</p>
                  </div>
                )}
              </div>
            )}
          </div>
        )}

        {/* Feedbacks do cliente */}
        <div style={styles.section}>
          <h3 style={styles.sectionTitle}>💬 Feedbacks Recentes</h3>
          {feedbacks.length === 0 ? (
            <p style={{ color: C.textMuted, fontSize: 13 }}>Nenhum feedback enviado ainda.</p>
          ) : (
            feedbacks.slice(-5).reverse().map(fb => (
              <div key={fb.id} style={styles.feedbackCard}>
                <div style={styles.feedbackHeader}>
                  <span style={styles.feedbackType}>{fb.type || 'Geral'}</span>
                  <span style={styles.feedbackDate}>
                    {new Date(fb.createdAt).toLocaleDateString('pt-BR')}
                  </span>
                </div>
                {fb.hunger !== undefined && (
                  <p style={styles.feedbackMeta}>Fome: {'★'.repeat(fb.hunger)}{'☆'.repeat(5 - fb.hunger)}</p>
                )}
                {fb.comment && <p style={styles.feedbackComment}>"{fb.comment}"</p>}
              </div>
            ))
          )}
        </div>

        <div style={{ height: 80 }} />
      </div>
    </div>
  );
}

