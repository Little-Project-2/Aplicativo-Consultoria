        <MetricCard label="Meta"  value={plan.targetCalories} unit="kcal/dia" icon="🎯" desc="Sua meta diária" color={C.accent} />
        <MetricCard label="Água"  value={(plan.waterMl/1000).toFixed(1)} unit="L/dia" icon="💧" desc="Hidratação recomendada" color={C.blue} />
      </div>

