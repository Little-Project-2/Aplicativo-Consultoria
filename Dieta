/**
 * FitPro — Tela de Perfil
 * Exibe dados, plano, histórico e permite envio de feedback
 */

import React, { useState, useCallback } from 'react';
import { useProfile, usePlan, useAuth, useActions } from '../context/AppContext';
import { feedbackService, getTodayKey } from '../services/firebase';
import { GOALS, ACTIVITY_FACTORS } from '../utils/calculations';

const C = {
  bg: '#0A0F1E', surface: '#111827', card: '#1F2937', border: '#374151',
  accent: '#00FF94', text: '#F9FAFB', textMuted: '#9CA3AF',
  error: '#EF4444', warning: '#F59E0B', blue: '#60A5FA',
  protein: '#EF4444', carbs: '#F59E0B', fat: '#8B5CF6',
};

export default function ProfileScreen() {
  const profile = useProfile();
  const plan    = usePlan();
  const auth    = useAuth();
  const { navigate, signOut, showToast } = useActions();

  const [tab, setTab] = useState('profile'); // profile | plan | feedback
  const [feedbackModal, setFeedbackModal] = useState(false);

  if (!profile || !plan) return (
    <div style={{ ...styles.container, alignItems: 'center', justifyContent: 'center' }}>
      <p style={{ color: C.textMuted }}>Carregando perfil...</p>
    </div>
  );

  const bmiColor = plan.bmi?.color || C.text;

  return (
    <div style={styles.container}>
      {/* Header */}
      <div style={styles.header}>
        <button onClick={() => navigate('dashboard')} style={styles.backBtn}>←</button>
        <h1 style={styles.headerTitle}>Meu Perfil</h1>
        <button onClick={signOut} style={styles.signOutBtn}>Sair</button>
      </div>

      {/* Avatar + Info */}
      <div style={styles.avatarSection}>
        <div style={styles.avatarCircle}>
          <span style={styles.avatarText}>
            {(profile.name || 'A').split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2)}
          </span>
        </div>
        <h2 style={styles.profileName}>{profile.name}</h2>
        <p style={styles.profileEmail}>{auth.user?.email}</p>
        <div style={styles.badgesRow}>
          <span style={styles.badge}>{GOALS[profile.goal]?.label || '—'}</span>
          <span style={{ ...styles.badge, backgroundColor: `${bmiColor}22`, color: bmiColor, borderColor: `${bmiColor}44` }}>
            IMC {plan.bmi?.value} · {plan.bmi?.classification}
          </span>
        </div>
      </div>

      {/* Tabs */}
      <div style={styles.tabs}>
        {[
          { id: 'profile',  label: '👤 Dados' },
          { id: 'plan',     label: '📊 Plano' },
          { id: 'feedback', label: '⭐ Feedback' },
        ].map(t => (
          <button key={t.id} onClick={() => setTab(t.id)}
            style={{ ...styles.tab, ...(tab === t.id ? styles.tabActive : {}) }}>
            {t.label}
          </button>
