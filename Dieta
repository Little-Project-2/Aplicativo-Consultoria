const AppContext = createContext(null);

export function AppProvider({ children }) {
  const [state, dispatch] = useReducer(appReducer, initialState);

  // ── Inicialização: verificar sessão ─────────
  useEffect(() => {
    const init = async () => {
      dispatch({ type: ACTIONS.SET_AUTH_LOADING, payload: true });
      try {
        const user = await authService.getCurrentUser();
        if (user) {
          dispatch({ type: ACTIONS.SET_AUTH_USER, payload: user });
          const profile = await userService.getProfile(user.uid);
          if (profile) {
            dispatch({ type: ACTIONS.SET_PROFILE, payload: profile });
            const plan = await nutritionService.getPlan(user.uid);
            if (plan) {
              dispatch({ type: ACTIONS.SET_NUTRITION_PLAN, payload: plan });
              dispatch({ type: ACTIONS.SET_SCREEN, payload: profile.role === 'professional' ? 'professional' : 'dashboard' });
            } else {
              dispatch({ type: ACTIONS.SET_SCREEN, payload: 'onboarding' });
            }
          } else {
            dispatch({ type: ACTIONS.SET_SCREEN, payload: 'onboarding' });
          }
        } else {
          dispatch({ type: ACTIONS.SET_SCREEN, payload: 'landing' });
        }
      } catch (e) {
        console.error('Init error:', e);
        dispatch({ type: ACTIONS.SET_SCREEN, payload: 'landing' });
      }
    };
    init();
  }, []);

  // Toast auto-clear
  useEffect(() => {
    if (state.ui.toast) {
      const t = setTimeout(() => dispatch({ type: ACTIONS.CLEAR_TOAST }), 3000);
      return () => clearTimeout(t);
    }
  }, [state.ui.toast]);

  // ── Actions Compostas ──────────────────────

  const actions = {

    // Auth
    signIn: useCallback(async (email, password) => {
      dispatch({ type: ACTIONS.SET_UI_LOADING, payload: true });
      try {
        const user = await authService.signIn(email, password);
        dispatch({ type: ACTIONS.SET_AUTH_USER, payload: user });
        const profile = await userService.getProfile(user.uid);
        if (profile) {
          dispatch({ type: ACTIONS.SET_PROFILE, payload: profile });
          const plan = await nutritionService.getPlan(user.uid);
          dispatch({ type: ACTIONS.SET_NUTRITION_PLAN, payload: plan });
          dispatch({ type: ACTIONS.SET_SCREEN, payload: profile.role === 'professional' ? 'professional' : 'dashboard' });
        } else {
          dispatch({ type: ACTIONS.SET_SCREEN, payload: 'onboarding' });
        }
      } catch (e) {
        dispatch({ type: ACTIONS.SET_AUTH_ERROR, payload: e.message });
        throw e;
      } finally {
        dispatch({ type: ACTIONS.SET_UI_LOADING, payload: false });
      }
    }, []),

    signUp: useCallback(async (email, password, displayName) => {
      dispatch({ type: ACTIONS.SET_UI_LOADING, payload: true });
      try {
        const user = await authService.signUp(email, password, displayName);
        dispatch({ type: ACTIONS.SET_AUTH_USER, payload: user });
        dispatch({ type: ACTIONS.SET_SCREEN, payload: 'onboarding' });
      } catch (e) {
        dispatch({ type: ACTIONS.SET_AUTH_ERROR, payload: e.message });
        throw e;
      } finally {
        dispatch({ type: ACTIONS.SET_UI_LOADING, payload: false });
      }
    }, []),

    signOut: useCallback(async () => {
      await authService.signOut();
      dispatch({ type: ACTIONS.SIGN_OUT });
    }, []),

    // Onboarding — salva perfil + gera plano
    completeOnboarding: useCallback(async (userData) => {
      dispatch({ type: ACTIONS.SET_UI_LOADING, payload: true });
      try {
        const uid = state.auth.user.uid;
        const profileData = { ...userData, uid, role: 'client', onboardingComplete: true };
        await userService.saveProfile(uid, profileData);
        dispatch({ type: ACTIONS.SET_PROFILE, payload: profileData });

        // Gerar plano nutricional
        const plan = generateNutritionProfile(userData);
        await nutritionService.savePlan(uid, plan);
        dispatch({ type: ACTIONS.SET_NUTRITION_PLAN, payload: plan });
        dispatch({ type: ACTIONS.SET_SCREEN, payload: 'dashboard' });
        actions.showToast({ message: '🎉 Plano nutricional criado!', type: 'success' });
      } catch (e) {
        actions.showToast({ message: e.message, type: 'error' });
      } finally {
        dispatch({ type: ACTIONS.SET_UI_LOADING, payload: false });
      }
    }, [state.auth.user]),

    // Daily log
    addFoodToMeal: useCallback(async (mealId, foodEntry) => {
      const uid = state.auth.user?.uid;
      const date = state.dailyLog.date;
      dispatch({ type: ACTIONS.ADD_FOOD_TO_MEAL, payload: { mealId, foodEntry } });
      if (uid) await dailyLogService.addFoodToMeal(uid, date, mealId, foodEntry);
    }, [state.auth.user, state.dailyLog.date]),

    removeFoodFromMeal: useCallback(async (mealId, entryId) => {
      const uid = state.auth.user?.uid;
      const date = state.dailyLog.date;
      dispatch({ type: ACTIONS.REMOVE_FOOD, payload: { mealId, entryId } });
      if (uid) await dailyLogService.removeFoodFromMeal(uid, date, mealId, entryId);
    }, [state.auth.user, state.dailyLog.date]),

    // Professional actions
    updateClientPlan: useCallback(async (clientUid, updates) => {
      const profUid = state.auth.user?.uid;
      dispatch({ type: ACTIONS.SET_UI_LOADING, payload: true });
      try {
        await nutritionService.updatePlanByProfessional(clientUid, updates, profUid);
        actions.showToast({ message: '✅ Plano atualizado com sucesso', type: 'success' });
      } catch (e) {
        actions.showToast({ message: e.message, type: 'error' });
      } finally {
        dispatch({ type: ACTIONS.SET_UI_LOADING, payload: false });
      }
    }, [state.auth.user]),

    // UI helpers
    navigate: (screen) => dispatch({ type: ACTIONS.SET_SCREEN, payload: screen }),
    openModal: (modal, data) => dispatch({ type: ACTIONS.OPEN_MODAL, payload: { modal, data } }),
    closeModal: () => dispatch({ type: ACTIONS.CLOSE_MODAL }),
    showToast: (toast) => dispatch({ type: ACTIONS.SHOW_TOAST, payload: toast }),
  };

  return (
    <AppContext.Provider value={{ state, dispatch, actions }}>
      {children}
    </AppContext.Provider>
  );
}

