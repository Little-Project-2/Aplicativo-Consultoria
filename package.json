{
    "name": "aplicativo-consultoria",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "generate:app-config": "node scripts/generate-app-config.mjs",
        "lint": "eslint src scripts vite.config.ts playwright.config.ts --ext .js,.mjs,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
