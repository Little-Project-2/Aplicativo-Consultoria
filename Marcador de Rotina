// ─────────────────────────────────────────────────────────────────────────────
// UTIL: Converte "HH:MM" → minutos (para ordenação cronológica)
// ─────────────────────────────────────────────────────────────────────────────
const timeToMinutes = (t) => {
  const [h, m] = t.split(":").map(Number);
  return h * 60 + m;
};

const formatDate = () =>
  new Date().toLocaleDateString("pt-BR", {
    weekday: "long", day: "2-digit", month: "long",
  });

