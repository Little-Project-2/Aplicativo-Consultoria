// SUBCOMPONENTE: StatRow
// Mini barra de progresso por categoria no card de resumo
// ═════════════════════════════════════════════════════════════════════════════
function StatRow({ label, done, total, color }) {
  const pct = total > 0 ? (done / total) * 100 : 0;
  return (
    <div className="flex items-center gap-2">
      <span className="text-xs text-gray-600 w-12 flex-shrink-0">{label}</span>
      <div className="flex-1 h-1 bg-gray-800 rounded-full overflow-hidden">
        <div
          className="h-full rounded-full transition-all duration-700 ease-out"
          style={{ width: `${pct}%`, backgroundColor: color }}
        />
      </div>
      <span className="text-xs font-mono text-gray-600 w-8 text-right flex-shrink-0">
        {done}/{total}
      </span>
    </div>
  );
}

// ═════════════════════════════════════════════════════════════════════════════
// SUBCOMPONENTE: ProgressRing
// Anel SVG circular com gradiente para exibir progresso geral do dia
// ═════════════════════════════════════════════════════════════════════════════
function ProgressRing({ percent }) {
  const r = 52;
  const circumference = 2 * Math.PI * r;
  const dashOffset = circumference * (1 - percent / 100);

  return (
    <div className="relative w-28 h-28 flex-shrink-0">
      <svg viewBox="0 0 128 128" className="w-28 h-28 -rotate-90">
        {/* Trilha de fundo */}
        <circle cx="64" cy="64" r={r} fill="none" stroke="#1e293b" strokeWidth="10" />
        {/* Progresso */}
        <circle
          cx="64" cy="64" r={r}
          fill="none"
          stroke="url(#ringGrad)"
          strokeWidth="10"
          strokeLinecap="round"
          strokeDasharray={circumference}
          strokeDashoffset={dashOffset}
          style={{ transition: "stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1)" }}
        />
        <defs>
          <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stopColor="#4ADE80" />
            <stop offset="100%" stopColor="#22D3EE" />
          </linearGradient>
        </defs>
      </svg>
      {/* Texto central */}
      <div className="absolute inset-0 flex flex-col items-center justify-center">
        <span className="text-2xl font-black text-gray-50 leading-none">
          {Math.round(percent)}%
        </span>
        <span className="text-xs text-gray-600 mt-0.5 font-medium">do dia</span>
      </div>
    </div>
  );
}

