          ? "opacity-40 border-gray-800/50 bg-gray-900/20"
          : "border-gray-800 bg-gray-900/60 hover:border-gray-700"
        }`}
      style={{ backdropFilter: "blur(12px)" }}
    >
      {/* Barra vertical de acento (por categoria) */}
      <div
        className="absolute left-0 top-3 bottom-3 w-0.5 rounded-r"
        style={{ backgroundColor: task.completed ? "#2a2a3a" : cfg.accent }}
      />

      <div className="p-4 pl-5">
        {/* Linha superior: horário + badges + menu */}
        <div className="flex items-center justify-between mb-2.5">
          <div className="flex items-center gap-2 flex-wrap flex-1 min-w-0">
            {/* Horário */}
            <div className="flex items-center gap-1">
