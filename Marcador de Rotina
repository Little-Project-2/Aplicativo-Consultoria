            {/* Nota opcional */}
            {task.note && (
              <p
                className={`text-xs mt-1 leading-relaxed ${
                  task.completed ? "text-gray-800" : "text-gray-500"
                }`}
              >
                {task.note}
              </p>
            )}
          </div>
        </div>

        {/* Badge de prioridade */}
        <div className="mt-3 ml-9">
          <PriorityBadge priority={task.priority} />
        </div>

        {/* Ações inline (editar / excluir) */}
        {actionsOpen && (
          <div className="mt-3 ml-9 flex items-center gap-2 animate-fade">
            <button
              onClick={() => { onEdit(task); setActionsOpen(false); }}
              className="flex items-center gap-1.5 px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 text-xs font-semibold text-gray-300 transition-colors"
